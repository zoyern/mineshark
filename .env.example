# ═══════════════════════════════════════════════════════════════════
#  MineShark — variables d'environnement
# ═══════════════════════════════════════════════════════════════════
#
#  Source de vérité pour TOUTE la configuration variable du projet.
#  Lu par : Makefile, docker-compose.yml, manifestes K8s (via commentaires
#  `# synced with .env` indiquant les valeurs miroirs).
#
#  DÉMARRAGE :
#      cp .env.example .env
#      (éditer .env)
#      make init      # crée data/, backups/ et génère les secrets auto
#
#  Le fichier .env est gitignored — volontaire, il peut contenir des infos
#  spécifiques à ton instance (IP VPS, CF_API_KEY).
#
#  Vérification de cohérence : `make doctor`
# ═══════════════════════════════════════════════════════════════════


# ─── Connexion au VPS ───────────────────────────────────────────────
# Utilisés par `make ssh` et `make deploy`. Laisse 127.0.0.1 si tu n'as
# pas encore de VPS — le repo reste publiable car .env est gitignored.
VPS_USER=mineshark
VPS_IP=127.0.0.1
VPS_SSH_PORT=22


# ─── Images Docker (toutes pinnées, jamais :latest en prod) ─────────
# Tags Java 21 = meilleures perfs pour Paper 1.21.x
IMG_PROXY=itzg/mc-proxy:java21
IMG_SERVER=itzg/minecraft-server:java21
IMG_BACKUP=itzg/mc-backup:latest
IMG_BUSYBOX=busybox:1.36.1


# ─── Serveur principal : fork et version ───────────────────────────
# SERVER_TYPE : fork Paper à utiliser sur le serveur principal.
#   • PAPER      = base, standard de facto, meilleure matrice plugins
#                  Modrinth. ** Choix par défaut MineShark ** — safe,
#                  maintenu par PaperMC, zéro surprise de compat.
#   • PURPUR     = fork Pufferfish (fork Paper) + features gameplay
#                  (double-jump, ride mobs, AFK). Plus de friction plugins
#                  (beaucoup publient pour paper mais pas purpur). À
#                  réactiver quand on aura besoin des features lobby.
#   • PUFFERFISH = Paper + optims perf pure, moins testé.
#   • FOLIA      = multi-thread régionalisé. Plugins incompatibles, fuyez.
# Voir docs/forks-comparison.md pour les détails.
SERVER_TYPE=PAPER

# 1.21.8 = LTS de facto (avril 2026). Sweet spot où TOUS les plugins sont
# officiellement testés et supportés :
#   • EssentialsX 2.21.2 : "actively develops for 1.21.8"
#   • WorldEdit 7.3.16   : supporte 1.21.3 → 1.21.8 (1.21.10 = untested)
#   • CoreProtect CE 23.x: supporte 1.21.8 nativement
# Au-dessus (1.21.9-11), plugins fonctionnent mais émettent des warnings
# "unsupported version" et l'adapter WorldEdit fallback sur v1_21_9.
# Pour rebumper : attendre WorldEdit 7.4.x stable + EssentialsX 2.22.x.
# Vérif rapide d'un plugin donné sur Modrinth :
#   curl -s https://api.modrinth.com/v2/project/worldedit/version | jq '.[0].game_versions'
# Pour monter en version : édite ici puis `make re` — aucun autre fichier
# à toucher.
PAPER_VERSION=1.21.8


# ─── Modpack (serveur moddé, indépendant du serveur plugin) ─────────
# TYPE = AUTO_CURSEFORGE télécharge via slug depuis curseforge.com.
# SLUG = la fin de l'URL : https://www.curseforge.com/minecraft/modpacks/<SLUG>
#
# Changer de modpack (cycle complet, ~10 min) :
#   1. Édite MODPACK_SLUG et MOD_MEMORY ci-dessous
#   2. Édite k8s/mod/deployment.yaml → CF_SLUG + MEMORY (même valeurs)
#   3. `make mod-reset && make mod-on`
#
# Packs TESTÉS server-friendly (1.21.1 NeoForge, ServerFiles officiels) :
#   • moddedtogether         fantasy/exploration (Mass Multiplayer) → MOD_MEMORY=6G (actuel, jouable 3-6 joueurs)
#   • all-the-mods-10        kitchen-sink géant (~500 mods)         → MOD_MEMORY=10G
#   • cobblemon-neoforge     officiel Cobblemon (Pokemon-like)      → MOD_MEMORY=3G
#   • medieval-mc-mmc5       medieval RPG (donjons, quêtes)         → MOD_MEMORY=6G
#
# ⚠️ PIÈGE VÉCU : CF_EXCLUDE_MODS (dans k8s/mod/deployment.yaml) attend
# des slugs CurseForge EXACTS = la FIN de l'URL curseforge.com/minecraft/
# mc-mods/<slug>. itzg IGNORE SILENCIEUSEMENT les slugs inconnus.
#   Ex. pour Modded Together :
#     ✗ "substrate"       → ignoré, crash au boot
#     ✓ "substrate-add-on" (URL : /mc-mods/substrate-add-on)
# Toujours vérifier via l'URL réelle du mod, PAS via le nom affiché.
#
# Avant d'adopter un pack, valider :
#   - ServerFiles disponibles sur la page CurseForge ? → bon signe
#   - Issues GitHub mentionnant dedicated server crash ? → les lire
MODPACK_TYPE=AUTO_CURSEFORGE
MODPACK_SLUG=moddedtogether
# MODPACK_FILE_ID=          # optionnel : bloquer une version précise (sinon dernière release)


# ─── Mémoire (valeurs PRODUCTION — VPS 16 Go) ──────────────────────
# Règle : limit K8s = MEMORY × 1.3 (marge metaspace + off-heap JVM)
#
# Budget 16 Go VPS (heap + overhead K8s ×1.33 pour mod, ×1.35 pour main) :
#   proxy    0.5 G  heap → limit  1 Gi
#   main     4   G  heap → limit  5.5 Gi
#   mod      6   G  heap → limit  8 Gi
#   K3s+OS  ~1.5 G
#   ─────────────────────────────
#   Total  ~16 Gi  → marge ~0.5-1 Gi
#
# Historiquement mod=8G (reco Modded Together pour 5-10 joueurs) mais
# heap 8G + overhead = limit 10Gi → total des limits = 18Gi > 16Go physique
# → risque OOMkiller kernel quand les 2 pods tirent au max. Baissé à 6G
# (jouable 3-6 joueurs actifs). Pour plus : bumper le VPS (Netcup 32Go).
#
# Alternatives gourmandes :
#   • ATM10 demande 10G heap → NE TIENT PAS sur 16Go physique avec mc-main
#     actif. Stopper mc-main (`make down`) avant de lancer ATM10.
#
# En DEV local (WSL 6-8 Go) : docker-compose.override.yml écrase
# automatiquement ces valeurs (256M / 1G / 3G). Ne pas les dupliquer ici.
PROXY_MEMORY=512M
MAIN_MEMORY=4G
MOD_MEMORY=6G


# ─── Ports publics ──────────────────────────────────────────────────
# Java principal + Bedrock passent par le proxy Velocity.
# Le moddé est standalone sur son propre port (pas derrière le proxy :
# Velocity force une version de protocole qui casserait NeoForge).
PORT_JAVA=25565
PORT_BEDROCK=19132
PORT_MOD=25566


# ─── Plugins serveur principal (Modrinth) ───────────────────────────
# Format : slug[:version] séparés par virgules. Lus par itzg via MODRINTH_PROJECTS.
# Ajouter un plugin : 1) ajoute son slug ici 2) `make re`. C'est tout.
# Voir docs/plugins.md pour la liste recommandée + alternatives.
#
# Stack par défaut (pro, complet, lobby + survie + mini-games, plugins
# maintenus 2026) :
#   ─ Bases permissions ─
#     luckperms        : permissions + groupes (standard de l'industrie)
#   ─ Édition mondes & protection ─
#     worldedit:7.3.16 : //set //paste /br — pin explicite (dernière
#                        qui supporte officiellement 1.21.8)
#     worldguard       : régions (protection lobby, arènes, shops)
#     coreprotect      : logs griefing + /co rollback
#   ─ Multiverse ─
#     multiverse-core  : lobby + mini-games dans le même serveur
#   ─ UX lobby & contenu ─
#     decentholograms  : hologrammes flottants (leaderboards, règles)
#     placeholderapi   : variables %player_name% etc. dans les plugins
#   ─ Navigation hub ─
#     advanced-portals : portails graphiques lobby ↔ hub-minigames
#                        (historique : tiré de Spiget ID 14356, l'API Spiget
#                         renvoyait HTTP 500 sur le download → migré sur
#                         Modrinth le 2026-04-20, slug `advanced-portals`)
#   ─ Skyblock moderne ─
#     bentobox         : plateforme Skyblock/OneBlock
#                        (historique : tiré de Spiget ID 73261, même panne
#                         API Spiget → migré sur Modrinth le 2026-04-20,
#                         slug `bentobox`. L'addon AOneBlock reste un jar
#                         manuel dans plugins/manual/bentobox-addons/.)
#   ─ Performance & admin ─
#     chunky           : pré-génération de chunks (évite le lag de gen live)
# Note : spark (profiler) retiré — pas de release Modrinth pour 1.21.x.
#        Paper fournit /tps natif. Si besoin de spark : URL directe dans PLUGINS.
#
# Plugins HORS Modrinth → téléchargés en direct (section PLUGINS du deploy) :
#   floodgate   : via download.geysermc.org (pas de Modrinth pour ce loader)
#   viaversion  : via GitHub releases (compat clients 1.8 → 1.21)
#   viabackwards: via GitHub releases (compat clients récents vers 1.8)
#   essentialsx : via GitHub releases — Modrinth lag (2.21.0 vs 2.21.2 GitHub)
#
# Plugins HORS Modrinth → via SPIGET_RESOURCES (SpigotMC, auto-téléchargés
# par itzg au boot via l'API Spiget) :
#   ─ Core/libs ─
#     vault                  : ID 34315  — API économie (prérequis bcp plugins)
#     protocollib            : ID 1997   — librairie paquets (dep WorldGuard/SWR/etc)
#   ─ Mini-jeux ─
#     tntrun_reloaded        : ID 53359  — TntRun (compat 1.13 → 1.21)
#     skywarsreloaded        : ID 69436  — SkyWars (fork lukasvdgaag, FREE)
#     screamingbedwars       : ID 63714  — BedWars maintenu 1.21.x (remplace BW1058)
#     spleef_reloaded        : ID 118673 — Spleef / Splegg (steve4744, remplace SpleefX)
#     mystery                : ID 66614  — MurderMystery Plugily-Projects
#     oitc                   : ID 81185  — One In The Chamber (Despical)
#   (bentobox déplacé dans PLUGINS_MODRINTH — Spiget 73261 en panne 2026-04)
#   ─ Divers ─
#     <ID 113931>            : slot existant, voir docs/plugins.md
#
# Plugins qui NE SONT PAS auto-installables (BuiltByBit payant, plugin
# disparu, jar custom, addon BentoBox) → voir plugins/manual/README.md
# pour le workflow "drop le jar + make plugins-sync".
PLUGINS_MODRINTH=luckperms,worldedit:7.3.16,worldguard,coreprotect,multiverse-core,decentholograms,placeholderapi,chunky,advanced-portals,bentobox
PLUGINS_SPIGET=34315,1997,53359,69436,63714,118673,66614,81185,113931


# ─── Gameplay ───────────────────────────────────────────────────────
# Couleurs MOTD : §a=vert §b=cyan §c=rouge §l=gras (codes Minecraft formatting)
MAIN_MOTD=§b§lMineShark §7- §aSurvie & Lobby
MOD_MOTD=§b§lMineShark §7- §cModdé
MAIN_MAX_PLAYERS=50
MOD_MAX_PLAYERS=30
DIFFICULTY_MAIN=normal
DIFFICULTY_MOD=hard
VIEW_DISTANCE=8
SIMULATION_DISTANCE=5


# ─── Secret manuel : CurseForge API ────────────────────────────────
# Seul secret a remplir a la main (cle externe).
# Generation : https://console.curseforge.com/?#/api-keys
# Laisse "change-me" si tu ne veux pas du serveur modde pour l'instant.
#
# /!\  ECHAPPEMENT OBLIGATOIRE — format bcrypt (dollar 2 a dollar 10 dollar ...)
# Make interprete tout "dollar-signe suivi d'un nom" comme reference de variable.
# Pour qu'il lise un dollar litteral dans la valeur, il faut le DOUBLER.
#
# Exemple :
#   cle reelle fournie par CurseForge :  $2a$10$aBcDeFgHiJkLmNoPqRsTuV
#   ce qu'il faut ecrire dans ton .env : $$2a$$10$$aBcDeFgHiJkLmNoPqRsTuV
#
# Cote shell (make/k8s.mk) on protege en plus avec des quotes simples, mais
# Make doit deja renvoyer la bonne valeur — d'ou le doublage ici.
# Verif rapide apres modif : `make show-secrets` (la cle affichee doit
# commencer par $2a$10$ — pas par des caracteres aleatoires type a0iABPw/C).
CF_API_KEY=change-me


# ─── Discord chat bridge (optionnel, serveur moddé) ────────────────
# Le mod `discord-chat-mod` est injecté sur TOUS les modpacks via
# MODRINTH_PROJECTS (cf. k8s/mod/deployment.yaml). Il relie le tchat
# in-game à un salon Discord : messages joueurs → Discord, messages
# Discord → tchat in-game, events connexion/déconnexion/mort.
#
# Si tu laisses ces 3 variables VIDES : le mod se charge mais ne se
# connecte pas (log WARN "Token may not be empty"). Le serveur boot
# et tourne normalement. Aucun impact.
#
# Si tu les remplis : l'initContainer `discord-config-patch` les
# injecte dans /data/config/discord_chat_mod-common.toml à chaque
# boot du pod. Survit à `make mod-reset` (le Secret K8s persiste).
# Le bot se connecte ~15s après le boot.
#
# ─ Setup bot Discord (5 min, une fois) ─
# 1. https://discord.com/developers/applications → New Application
#    → onglet "Bot" → Reset Token → copie-le dans DISCORD_TOKEN
# 2. Dans le même onglet Bot, active les 3 "Privileged Gateway Intents" :
#      - Presence Intent
#      - Server Members Intent
#      - Message Content Intent
# 3. Onglet OAuth2 → URL Generator :
#      - Scopes :       bot
#      - Permissions :  View Channels, Send Messages, Read Message History,
#                       Embed Links, Manage Webhooks
#    Copie l'URL générée, ouvre-la, invite le bot sur TON serveur Discord.
# 4. Sur Discord : active le "Mode développeur" (Paramètres → Avancés)
#    puis clic-droit sur ton serveur → "Copier l'identifiant du serveur"
#    → colle dans DISCORD_GUILD_ID.
# 5. Clic-droit sur le salon qui recevra le tchat MC → "Copier l'identifiant"
#    → colle dans DISCORD_CHANNEL_ID.
#
# Doc complète + dépannage : docs/discord.md
#
# ⚠️ Ces 3 valeurs sont des SECRETS — .env est gitignored, ne les
# committe jamais. Si un token fuite : reset immédiat dans le portail
# Developer puis `make discord-setup`.
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=


# ═══════════════════════════════════════════════════════════════════
#  SECRETS AUTO-GÉNÉRÉS — NE PAS DÉFINIR ICI
# ═══════════════════════════════════════════════════════════════════
#  Les fichiers suivants sont créés par `make init` ou `make secrets` :
#     data/secrets/rcon.secret              (RCON password — 24 hex)
#     data/velocity/forwarding.secret       (Velocity modern forwarding)
#
#  Pour voir leurs valeurs : `make show-secrets`
#  Ne les committe JAMAIS — ils sont gitignored via data/.
# ═════════════════════════════════════════════════════════════════