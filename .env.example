# ═══════════════════════════════════════════════════════════════════
#  MineShark — variables d'environnement
# ═══════════════════════════════════════════════════════════════════
#
#  Source de vérité pour TOUTE la configuration variable du projet.
#  Lu automatiquement par :
#    • le Makefile (et ses sous-makefiles dans make/)
#    • docker-compose.yml (interpolation native ${VAR})
#    • les manifestes K8s — pour celles qui sont dupliquées en YAML,
#      un commentaire « # synced with .env » signale la valeur miroir.
#
#  Pour démarrer : cp .env.example .env  puis éditer .env
#  Le fichier .env est gitignored — c'est volontaire (secrets).
#
#  Vérification de cohérence : `make doctor`
# ═══════════════════════════════════════════════════════════════════


# ─── Connexion au VPS ───────────────────────────────────────────────
# Utilisés par la cible `make ssh` et par `make deploy` (push git distant).
VPS_USER=mineshark
VPS_IP=127.0.0.1
VPS_SSH_PORT=22


# ─── Versions Docker (toujours pinned, jamais :latest) ──────────────
# itzg/minecraft-server : voir les tags sur https://hub.docker.com/r/itzg/minecraft-server
# itzg/mc-proxy         : voir https://hub.docker.com/r/itzg/mc-proxy
# Aikar flags + Java 21 = perfs maximales sur Paper 1.21+
IMG_PROXY=itzg/mc-proxy:java21
IMG_SERVER=itzg/minecraft-server:java21
IMG_BACKUP=itzg/mc-backup:latest
IMG_BUSYBOX=busybox:1.36.1


# ─── Versions Minecraft ─────────────────────────────────────────────
# Dernière stable Paper supportée par tous les plugins listés (voir docs/plugins.md)
PAPER_VERSION=1.21.4
# Loader moddé : NeoForge 1.21.x — version auto-déterminée par AUTO_CURSEFORGE


# ─── Modpack (serveur moddé) ────────────────────────────────────────
# Type : AUTO_CURSEFORGE (téléchargement auto via slug) ou CUSTOM (jars manuels)
# Slug = la fin de l'URL CurseForge : https://www.curseforge.com/minecraft/modpacks/<SLUG>
# Pour changer de modpack, modifier juste la ligne ci-dessous puis : make mod-reset
MODPACK_TYPE=AUTO_CURSEFORGE
MODPACK_SLUG=moddedtogether
# Optionnel : forcer une version précise du modpack (sinon = dernière)
# MODPACK_FILE_ID=


# ─── Mémoire allouée (heap Java) ────────────────────────────────────
# Règle d'or : limit K8s = MEMORY + 30% (marge metaspace + off-heap)
PROXY_MEMORY=512M
MAIN_MEMORY=3G
MOD_MEMORY=8G


# ─── Ports publics (joueurs) ────────────────────────────────────────
PORT_JAVA=25565
PORT_BEDROCK=19132


# ─── Plugins serveur principal (Modrinth) ───────────────────────────
# Liste séparée par virgules, lue par itzg/minecraft-server via MODRINTH_PROJECTS.
# Format : <slug-modrinth>[:version]   (ex: luckperms:5.4.150)
# Voir docs/plugins.md pour la liste recommandée + alternatives.
PLUGINS_MODRINTH=floodgate,luckperms,worldedit,worldguard,coreprotect,multiverse-core,placeholderapi,spark,chunky,decent-holograms


# ─── Gameplay ───────────────────────────────────────────────────────
# Couleurs MOTD : §a=vert §b=cyan §c=rouge §l=gras (cf. doc Minecraft formatting codes)
MAIN_MOTD=§b§lMineShark §7- §aSurvie & Lobby
MOD_MOTD=§b§lMineShark §7- §cModdé
MAIN_MAX_PLAYERS=50
MOD_MAX_PLAYERS=30
DIFFICULTY_MAIN=normal
DIFFICULTY_MOD=hard
VIEW_DISTANCE=8
SIMULATION_DISTANCE=5


# ─── Secrets — JAMAIS COMMITER ──────────────────────────────────────
# Mot de passe RCON : généré une fois, partagé entre tous les serveurs MC
RCON_PASSWORD=change-me-please

# Clé API CurseForge : https://console.curseforge.com/?#/api-keys
# Nécessaire seulement si MODPACK_TYPE=AUTO_CURSEFORGE
CF_API_KEY=change-me-please

# Forwarding secret Velocity ↔ backends : généré auto par `make secrets`
# (laisser vide ici — sera dans data/velocity/forwarding.secret)
