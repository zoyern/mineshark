# ═══════════════════════════════════════════════════
#  MineShark — .gitignore
# ═══════════════════════════════════════════════════

# ---------------------------------------------------
# Secrets & environnement
# ---------------------------------------------------
.env
*.secret
forwarding.secret

# ---------------------------------------------------
# Données serveurs MC — ON IGNORE TOUT data/
# Seuls les fichiers de CONFIG qu'on veut versionner
# seront ajoutés en force avec : git add -f data/velocity/velocity.toml
# ---------------------------------------------------
data/

# ---------------------------------------------------
# Ancien serveur Spigot (SkulyCube)
# ---------------------------------------------------
mc-server-old/

# ---------------------------------------------------
# Binaires, archives, DB
# ---------------------------------------------------
*.jar
*.tar.gz
*.zip
*.db
*.sqlite

# ---------------------------------------------------
# OS / Éditeurs
# ---------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ---------------------------------------------------
# Node / Web (pour le futur site)
# ---------------------------------------------------
node_modules/
dist/
.next/
.nuxt/
