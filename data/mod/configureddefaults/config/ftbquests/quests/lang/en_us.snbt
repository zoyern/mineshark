	quest.57E22AC608667A48.quest_subtitle: "Claim what you want, and never stop"
	quest.57EBF3989530A592.quest_desc: [
		"The &6&lLinear Chassis&r&r is a core block used to build Contraptions."
		""
		"Linear Chassis will automatically connect to adjacent chassis that are aligned in the same direction."
		"To attach blocks to either of its piston-like faces, apply a Slimeball or Super Glue. These items are not consumed during use."
		""
		"Use a Wrench and scroll while hovering over a side to adjust how many blocks the chassis will move in that direction. Hold Ctrl while scrolling to adjust all connected chassis at once."
		""
		"Independent Chassis: "
		""
		"To place adjacent chassis that don't connect, use a &6&lSecondary Linear Chassis&r&r."
	]
	quest.57EBF3989530A592.quest_subtitle: "Contraption structure"
	quest.58120F1AB50496B7.quest_desc: [
		"&l&o&9Modded Together&r at its core is an adventure modpack — but adventure here means far more than just exploring."
		""
		"You will find many paths to follow."
		""
		"Nearly every part of Minecraft has been expanded, integrated.  "
		""
		""
		"{image:kubejs:textures/quests/ars-jpg.png width:320 height:180 align:center fit:true}"
	]
	quest.58120F1AB50496B7.quest_subtitle: "The Journey Begins"
	quest.58287229B7469DF8.title: "Old Warped Woods"
	quest.5840D87848529342.quest_desc: [
		"Produces rotational power without fuel."
		""
		"Attach at least &68 sail-type blocks&r to create a windmill."
		"Valid sails include &6Sails, Sail Frames, Wool, or Copycat Panels with wool&r."
		""
		"Additional blocks can be attached using &6Super Glue&r, but they do not increase power."
		""
		"&8● &6Power&r"
		"Power increases with the number of sails."
		"Maximum: &6128 sails&r."
		""
		"&8● &6Rotation&r"
		"Windmills spin clockwise by default."
		"Use a &6Wrench&r to reverse the direction."
	]
	quest.5840D87848529342.quest_subtitle: "Passive power generation"
	quest.58512B52B974806B.quest_subtitle: "Tectonic Ward ability. Fire and Nature school bonuses"
	quest.58512B52B974806B.title: "Tectonic Crest Armor"
	quest.585A2CD65F9FB12D.quest_desc: ["Necromium armor &bweakens&r enemies when they hit you. When you hit enemies with necromium weapons, they become &bslower&r momentarily."]
	quest.585A2CD65F9FB12D.quest_subtitle: "Slow and Steady"
	quest.585A2CD65F9FB12D.title: "Necromium Armor"
	quest.589995B5F40D8570.quest_desc: [
		"Shafts carry rotational force between machines."
		"They are needed to connect gears, belts, and other parts."
		"Most moving builds rely on them."
		"Craft extra. Running out slows everything down."
	]
	quest.589995B5F40D8570.quest_subtitle: "Connecting everything together"
	quest.589995B5F40D8570.title: "Shafts"
	quest.58AB7435DE810CF2.quest_desc: [
		"&aPros:&r"
		"&8●&r Malignant Critical Strikes devour life essence"
		"&8●&r Devoured essence heals based on damage dealt"
		""
		"&4Cons:&r"
		"&8●&r Overusing the healing effect reduces incoming healing over time"
