	quest.00A3E63B6ED92FAB.quest_desc: [
		"The &6Mechanical Harvester&r automatically harvests fully grown crops when mounted on a moving contraption."
		""
		"Collected crops are stored in an inventory on the contraption."
		"If no inventory is present, the items drop on the ground."
		""
		"Harvested crops are replanted at their first growth stage."
	]
