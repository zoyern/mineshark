	quest.1EC8C50FB0107340.quest_desc: ["When placed next to an inventory blcok (chest, vault, barrel) it connects any inventory blocks touching the first one into one large inventory network. In order to access your inventory network, you must have a storage terminal."]
	quest.1ED0362F9ACF715F.quest_desc: ["{image:gamma_creatures:textures/screens/sppinto_eng2.png width:150 height:100 align:center fit:true}"]
	quest.1EE32DBF0AC9F485.quest_desc: [
		"This build strength is depend on user skill and item from this build won't have exact guide as it also hidden. By combining all item in this build together will make you a decent build with unique gameplay and strength."
		""
		"Item from this build will be shown above when you unlock them."
	]
	quest.1EE86383DE5C8BA5.title: "Marketstead Village"
	quest.1F10BC33D22328BD.quest_desc: ["Time has claimed this once-sacred site, leaving its halls cracked and overgrown. Now, ghostly skeletons and trickster illusioners linger within, guarding little more than shadows of former glory. Though its dangers are real, the temple’s sturdy walls make it a tempting refuge for those seeking a foothold in this hostile world."]
	quest.1F10BC33D22328BD.quest_subtitle: "Find an Abandoned Temple"
