	quest.35FDACB27408FC07.quest_desc: ["Use it to view magic upgrades applied to Familiars"]
	quest.35FDACB27408FC07.quest_subtitle: "Eye for upgrades"
	quest.360942E71C903533.quest_subtitle: "Blinds and slows hostile nearby hostile mobs"
	quest.364C0861EBB7630E.quest_desc: [
		"The &6Storage Tool&r is used to manage and configure &6Sophisticated Storage&r systems."
		""
		"&8● &6Controls&r"
		"Shift + Scroll — Change mode."
		""
		"&8● &6Linking&r"
		"Right-click a &6Controller&r to start linking."
		"Then right-click storages or &6Storage Links&r to connect them."
		""
		"To unlink, shift-right-click in the air to enter unlink mode, then select the connection to remove."
		""
		"&8● &6Locking&r"
		"Right-click a storage or &6Controller&r to lock or unlock it."
		""
		"&8● &6Visibility&r"
		"Right-click a storage or &6Controller&r to toggle lock and item count visibility."
	]
	quest.364C0861EBB7630E.quest_subtitle: "Storage management"
	quest.3653EDC8E40D67DA.quest_desc: [
		"This gigantic and radioactive beast can be spawned by getting a &k&aNuclear Bomb&r or &k&aNucleeper&r to explode on top of a &k&6Tremorzilla Egg&r. The &k&6Egg&r can be crafted with the drops from &k&9Hullbreakers&r and &k&cLuxtructosauruses&r. Tame the Tremorzilla using &k&aWaste Drums&r."
		""
		"&7Hint: Deciphering the Cave Compendium might give you more help with this."
	]
	quest.36709298CF93EDDB.title: "Airship Village"
	quest.3679A75EE5E61626.quest_desc: ["Empty tablet is needed to craft others"]
	quest.3679A75EE5E61626.quest_subtitle: "Some basic utilities"
