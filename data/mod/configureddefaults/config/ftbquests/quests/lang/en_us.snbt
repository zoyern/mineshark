	quest.6BAA73A56012674B.title: "Pirate Village"
	quest.6BD17F61D64105FF.quest_desc: [
		"&aPros:&r"
		"&8●&r Fire effects inflicted on enemies are amplified"
		""
		"&4Cons:&r"
		"&8●&r Being forcibly extinguished triggers Infernal Arcana on you"
		""
		""
		"&8Pedestal Items:&r"
		"8x Blaze Powder"
		"4x Blazing Quartz"
		""
