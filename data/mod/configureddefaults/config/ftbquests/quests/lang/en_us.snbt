	quest.1C0493975473E23A.quest_subtitle: "Increases mana amount and regen rate. Decreases attack damage"
	quest.1C375606107C117F.quest_subtitle: "Find Keep Kayra"
	quest.1C3DBD984E973953.quest_desc: [
		"Start with the &bMason Table&r.  "
		"Place it, then use it to change the look of a block.  "
		"Try it with cobblestone — your base floor can look better without much cost."
		""
		"Unlocks the &6Building Essentials&r chapter."
	]
	quest.1C3DBD984E973953.quest_subtitle: "Easier and better than ever"
	quest.1C3DBD984E973953.title: "Building Basics"
	quest.1C76316EF49F3B0B.quest_desc: ["Born from &7soul sand&r and the &8tormented spirits&r of the dead, the Wither embodies hatred, rage, and fear. These emotions fuel its destruction, driving it to attack all living things as it drifts through the skies."]
	quest.1CAD3BB2D5A8E0F1.quest_desc: [
		"The &bSpirit Crucible&r can be enhanced using augments."
		""
		"Augments are created using &bAlchemical Calx&r."
		""
		"Insert augments into the &bSpirit Catalyzer&r,"
		"or place up to four directly in the Crucible."
		""
		"Multiple copies of the same augment stack their effects."
		""
		"Use the &bTuning Fork&r to inspect resonances."
		""
		"Right-click the Crucible with the Tuning Fork to boost one attribute."
		""
		"Improving one attribute reduces others."
	]
	quest.1CAD3BB2D5A8E0F1.quest_subtitle: "Upgrade the Spirit Crucible"
	quest.1CAD3BB2D5A8E0F1.title: "Crucible Augmentation"
	quest.1CCA31D9352C60E6.quest_desc: ["Clustered around a towering central “grandmother” mushroom, these villages appear quaint from afar. Yet the villagers within are far more aggressive than their old-world counterparts, hiding a cunning fierceness beneath their colorful caps. Approach with caution as this village may welcome the unwary only to spring its traps."]
	quest.1CCA31D9352C60E6.quest_subtitle: "Find a mushroom village"
	quest.1CDE41D6BCC6DDD0.quest_desc: ["Endgame bow, strong deadly shot, this is what had taken down many live by &4Maledictus&r. Holding this in hand bring a weird feeling about the death."]
	quest.1CEF2A38948010A2.quest_desc: ["Out on the open seas, the &6Illagers&r have taken to the waves, commandeering massive galleys and swift corsairs. Their sails cast long shadows, and their cannons roar with fury. Only the bravest dare to board, for fortune favors those who seize it."]
	quest.1CEF2A38948010A2.quest_subtitle: "Find an Illager Corsair or an Illager Galley"
	quest.1CF4D693319F333F.title: "Desert Pyramid"
	quest.1D05295C6313360F.title: "Tavern Village"
	quest.1D92946E2522A63F.quest_desc: ["A fern that seems to grab you first. Its sprigs cling tightly to anything passing by. With the right use, it may serve as a binding reagent."]
	quest.1D92946E2522A63F.quest_subtitle: "Clinging Fern"
	quest.1DBCE49270D2E2C5.title: "Enderwatch Tower"
	quest.1DDCF59C7FAA9EB8.quest_desc: [
		"The &bPrismatic Focus Lens&r redirects the flow of arcana."
		""
		"It reduces Crucible instability."
		""
		"Stability only prevents additional damage to the Impetus."
		""
		"It does not restore lost durability."
	]
	quest.1DDCF59C7FAA9EB8.quest_subtitle: "Reduce instability"
