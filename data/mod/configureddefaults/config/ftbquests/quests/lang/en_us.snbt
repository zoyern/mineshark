	quest.7623E20796E1BD79.quest_subtitle: "{components:{\"ftbquests:loot_crate\":\"food1\"},count:1,id:\"ftbquests:lootcrate\"}"
	quest.762EEF712ACEED01.quest_desc: ["Complete yellow &eSempiternal Sanctum&r challenge."]
	quest.7658031A2D941FA5.quest_desc: [
		"Like Minecraft itself, in the end — your path is your own.  "
		"There is no single goal, only what you choose to pursue.  "
		"Still, here are a few ideas to guide your journey:"
		""
		"&8●&r Defeat the Ender Dragon  "
		""
		"&8●&r Complete the Boss Codex  "
		""
		"&8●&r Create your school’s special armor, such as the Paladin set  "
		""
		"&8●&r Discover all archaeology eggs  "
		""
		"&8●&r Forge the Shadow Radiance armor  "
		"  "
		"&8●&r Create a full storage network with a Storage Controller  "
		""
		"&8●&r Maximize your hearts by cooking every comforting meal  "
		""
		"&8●&r And finally, explore everything together with friends, or find new ones on &z&lOfficial Server&r&r!"
	]
	quest.7658031A2D941FA5.quest_subtitle: "What to Do"
	quest.7658031A2D941FA5.title: "Purpose"
	quest.766AB4D78945AC31.quest_desc: ["An &5Enchanting apparatus&r works similarly to an &5Imbuement chamber&r; however, the setup will be slightly diffirent. To make it, you need to place an &5Enchanting apparatus&r above &5Arcane core&r. When this setup is surrounded with 8 &5Arcane pedestal&r, all recipes will be possible, "]
	quest.768B5A37B86F75E3.title: "Withered Vault"
	quest.76A81A7A53F5A289.title: "Soul Black Smith"
	quest.76B16225129CA5BA.quest_desc: [
		"&bRune Of Howling Gale&r increases movement speed and attack speed."
		""
		"Effect is moderate."
	]
	quest.76B16225129CA5BA.quest_subtitle: "Speed and aggression"
	quest.76B1F24FEBBE224D.title: "Silver Knight"
	quest.76CC048EC4EBA73E.quest_desc: ["&ePotion Flask&r have two types. Amplify will increase 1 level effect for the potion when applied and Extend will increase 50% duration time for the potion when applied."]
	quest.76CC048EC4EBA73E.quest_subtitle: "Stronger or longer?"
	quest.76CC048EC4EBA73E.title: "Potion Flask"
	quest.76DAECF378BA3F19.quest_desc: ["Far beneath the surface lies a labyrinth of rails and tunnels, carved by long-forgotten hands. The air is thick with dust and danger. Creatures lurk in the shadows, and the echoes of minecarts rattle through the dark. Yet for those who endure, veins of treasure and hidden chambers make the descent worthwhile."]
	quest.76DAECF378BA3F19.quest_subtitle: "Find a Mining System"
	quest.770531739B2BC9AB.title: "Ancient Treasures I"
	quest.7711262D94A60D1C.quest_subtitle: "Permanent resistance"
	quest.77667929B0FE5B92.quest_desc: [
		"As you deliver the last of the items to the &6Witch&r, she congratulates you."
		""
		"&b\"You truly are a prodigy. Here, have one of these rare potions. They're pretty difficult to make, but you've earned it.\"&r"
	]
	quest.77667929B0FE5B92.quest_subtitle: "Trade for Unique Potions!"
	quest.77667929B0FE5B92.title: "Compound Potions"
	quest.777ECEC887B1CA2D.quest_subtitle: "{components:{\"ftbquests:loot_crate\":\"materials\"},count:1,id:\"ftbquests:lootcrate\"}"
	quest.77B22F28C4718378.quest_desc: [
		"Deep in the ocean lies the &9Sunken City&r, where whispers of the &1Leviathan&r still echo through flooded halls. It is a monstrous being, vast as a mountain, its tendrils moving like living storms beneath the waves."
		""
		"The creature is worshiped by those twisted by the deep, guarding the &5Altar of the Abyss&r built in its name. Its &3Abyssal magic&r poisons water and soul alike, devouring all that approach."
		""
		"They say the &9Eye of Abyss&r can reveal the altar’s location."
		"Find it if you dare—but know this: the ocean has already chosen its god."
		"{image:kubejs:textures/quests/cataclysm/the_leviathan.png width:100 height:100 align:center fit:true}"
	]
	quest.77E47B660E2517D8.quest_desc: ["A mage should have a staff atleast, let's make decent equipment before going out test your spell."]
	quest.77E47B660E2517D8.title: "Wizard"
	quest.780F8E2C9E617768.quest_desc: [
		"Runewood is a naturally magic-infused tree."
		"It is commonly found in plains and sometimes forests."
		"Its orange-yellow leaves make it easy to identify."
		""
		"&8●&r &bArcane Charcoal&r — burns longer than regular charcoal."
		"&8●&r &bRunic Sap&r — collected by stripping sap-covered logs."
		"&8●&r &bSapballs&r — crafted from sap, usable like slimeballs."
		""
		"Runewood is used as a base material for many arcane structures and recipes."
	]
	quest.780F8E2C9E617768.quest_subtitle: "Magical tree of the plains"
	quest.780F8E2C9E617768.title: "Runewood"
	quest.782FBC8A3A98E7AC.quest_desc: ["More powerful than mage but less utilities, this build allow you to use not only magic side but also can use other class item, by using magic combine with these item you will able to fight boss and really deal damage."]
	quest.786374C18337A919.quest_desc: ["These components act very similar to their vanilla/andesite counterparts, but with more options. Brass components allow for filtering by item type, size, etc. For more information on specific components, ponder the item."]
	quest.786374C18337A919.title: "\"Smart\" Items"
	quest.7867DEB7C916F9D2.quest_desc: [
		"There are many forgotten ruins, temples, and dungeons that dot the lands. Many contain &bitems&r or &bknowledge&r that will be useful in your adventures."
		""
		"You may come across &5Rumors&r on where to find these locations. If so, I will log them in this chapter for you."
	]
	quest.7867DEB7C916F9D2.title: "Explore the Lands"
	quest.7883020E943D49F6.quest_desc: [
		"Runewood logs sometimes ooze sticky sap. Strip the bark to collect it and drink it to heal. "
		""
		"It tastes sweet with an earthy note. "
		""
		"The sap can also be made into sapballs, like slimeballs, or turned into rubber for crafting."
	]
	quest.7883020E943D49F6.quest_subtitle: "Rejuvenating Sap"
	quest.7883020E943D49F6.title: "Runewood Sap"
	quest.78A73FF9E2F525EB.quest_desc: [
		"- Combat is improved through the &e\"Better Combat\"&r mod. Try it for yourself!"
		""
		"- There are multiple new types of weapons. Each has different combat properties, so try several."
		""
		"- &bShields&r have been reworked through the &e\"Shield Expansion\"&r mod. &bShields&r are now disabled upon being hit, but if you time your block right when attacked (parry), the cooldown is bypassed and melee attackers are pushed back."
	]
	quest.78A73FF9E2F525EB.title: "Combat Tweaks"
	quest.78FC6CE082692A76.quest_desc: [
		"Place a &6Fluid Hatch&r on a &6Fluid Tank&r to interact with stored fluids."
		""
		"Right-click with a fluid container to fill or deposit fluid."
	]
	quest.78FC6CE082692A76.quest_subtitle: "Manual fluid access"
	quest.7927B2581B383040.quest_desc: [
		"The &bWarping Engine&r uses &bWarp Flux&r to distort the focusing process."
		""
		"After a normal cycle completes, it can trigger an additional cycle instantly."
		""
		"Chained activations increase all other Crucible attributes."
		""
		"Fuel consumption increases significantly."
		""
		"Tuning becomes slightly more strained."
	]
	quest.7927B2581B383040.quest_subtitle: "Extra cycles at a cost"
	quest.794F10DFF56A82EE.title: "Food store"
	quest.7959A303339364CF.quest_subtitle: "{components:{\"ftbquests:loot_crate\":\"food2\"},count:1,id:\"ftbquests:lootcrate\"}"
	quest.795C0F22F2C649BA.quest_subtitle: "&l&n&5A weapon forged to watch for eternity!"
	quest.79DB41984ACBE7BC.title: "Mushroom Fields"
	quest.7A101769F340E522.quest_desc: ["{image:gamma_creatures:textures/screens/lennat_eng2.png width:150 height:100 align:center fit:true}"]
	quest.7A413E106A44B9B8.quest_desc: [
		"&#6EC1FFSimple Rite&r"
		""
		"While active, it blesses nearby creatures with Burning Fervor."
		"Attack speed and mining speed increase."
		""
		"[  ]"
