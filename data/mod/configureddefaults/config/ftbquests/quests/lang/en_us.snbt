	quest.3BA21B990625F684.quest_subtitle: "Step. Form. Ready. Raise. Begin. Draw. Release."
	quest.3BA44EB64742E3F7.quest_desc: ["Reforging table allow to forge all tier affix"]
	quest.3BD7B772B404B878.quest_desc: ["Find and enter &4Throne Pillar Structure&r"]
	quest.3C0A30E13C5D0F80.title: "Choo Choo!"
	quest.3C1A9DC6312F1349.quest_desc: ["Finish all the desire task from &eBee Queen&r"]
	quest.3C510AA36D63F0F5.quest_desc: [
		"Scythes are used to harvest &bSpirit Crystals&r from enemies."
		""
		"Killing creatures with a scythe causes their souls to shatter."
		"Shattered souls release spirit crystals toward you."
		""
		"Scythes deal less damage than swords, but enable spirit collection."
	]
	quest.3C510AA36D63F0F5.quest_subtitle: "Harvesting spirit crystals"
	quest.3C510AA36D63F0F5.title: "Scythes"
	quest.3C5980F7AEDDD54D.title: "Forests"
	quest.3C6685089661DB0E.quest_desc: ["{image:gamma_creatures:textures/screens/dosmo_eng2.png width:151 height:100 align:center fit:true}"]
	quest.3C6A9B5933DA9FF9.quest_desc: [
		"&bRune Of Radial Empowerment&r increases weapon damage after scythe kills."
		""
		"Bonus lasts for a short duration."
	]
	quest.3C6A9B5933DA9FF9.quest_subtitle: "Power from kills"
	quest.3C786EE238E73E80.quest_desc: [
		"Not much is known about the &5Nightwarden &rother than he was a once peaceful mage who became trapped in limbo while attempting to find the one he lost. His body is kept safe in the &9Void Cathedral.&r Perhaps there you will find more information, including clues on how to battle him..."
		"{@pagebreak}"
		"The Nightwarden is found in the Void Cathedral in &5the End.&r Use an &6Eye of Nothingness&r to locate it. R-click on the shadow-y figure with Excrusis to awaken him. "
	]
	quest.3C9061B95D2C682B.quest_desc: ["                                    &9Check To See"]
	quest.3C9411E253A53D2C.quest_desc: [
		"The &6Basic Tier Upgrade&r is the starting upgrade for &6Sophisticated Storage&r."
		""
		"It allows vanilla chests, barrels, and shulker boxes to be converted into Sophisticated Storage variants."
		""
		"Upgrading your storage unlocks additional features and upgrade slots."
	]
	quest.3C9411E253A53D2C.quest_subtitle: "Storage conversion"
	quest.3CA0142DF18BC8D8.title: "Undying Warrior"
	quest.3CB6FAB718198DE7.quest_desc: [
		"&#6EC1FFSimple Rite&r"
		""
		"While active, it grants effects similar to Lure and Luck of the Sea."
		""
