	quest.635E8B759C02188F.title: "Alpha Grove"
	quest.63712DE5AE6ED43D.quest_desc: [
		"The &6Spirit Altar&r is used to infuse items with arcana."
		""
		"Place the main item on the altar."
		""
		"Place required arcana also on the altar"
		"Place any additional items on runewood &6pedestals&r within 4 blocks."
		""
		"When all arcana are present, the infusion begins."
		"The process is slow."
	]
	quest.63712DE5AE6ED43D.quest_subtitle: "Using the Spirit Altar"
	quest.63712DE5AE6ED43D.title: "Spirit Infusion"
