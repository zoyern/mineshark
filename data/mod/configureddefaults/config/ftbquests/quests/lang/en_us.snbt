	quest.353FC18F3B4378CA.quest_desc: ["{image:gamma_creatures:textures/screens/juvex_eng2.png width:150 height:100 align:center fit:true}"]
	quest.357AD72C3B07464A.quest_desc: [
		"The &bSpirit Jar&r is used to store spirits."
		""
		"Each jar can hold only one type of spirit."
		""
		"Its capacity is extremely high."
		""
		"Use jars to stockpile spirits for rituals and infusions."
	]
	quest.357AD72C3B07464A.quest_subtitle: "Storing raw spirits"
	quest.35B82892BA4794AC.quest_desc: ["Kiting build with high speed, this build help you not only in exploring but also in boss fight in exchange will have lower armor, hp than warrior build."]
	quest.35BF089B3426F232.quest_desc: [
		"&6Package Frogports&r send and receive Cardboard Packages from &6Chain Conveyors&r."
		""
		"To place one, right-click a &6Chain Conveyor&r and position the &6Frogport&r up to 4 blocks away and at least 1 block lower."
		""
		"Open the &6Frogport&r to assign an address."
		"It will only accept packages with the same address."
		""
		"If no matching &6Frogport&r exists, the package will keep moving on the &6Chain Conveyor&r until a valid destination appears."
		""
		"&8● &6Automation&r"
		"&6Frogports&r can connect to storage placed beneath them, allowing packages to be unpacked or inserted automatically."
		""
		"Use a &6Clipboard&r on a &6Frogport&r to copy its address."
		"Saved addresses can then be used to auto-complete address fields in other interfaces."
	]
	quest.35BF089B3426F232.quest_subtitle: "Package routing"
	quest.35CEE121B754C216.title: "Flower Fields"
	quest.35D4765B6555620B.quest_subtitle: "Create every glyph"
	quest.35D4765B6555620B.title: "Glyph Master"
	quest.35D71AB41E3127FF.quest_desc: [
		"You will need a lot of andesite.  "
		"While exploring caves, finding it gives a simple chance to learn the basics of &6&lCreate&r."
		""
		"A common stone, but the start of many machines."
		""
		"Unlocks the &6Andesite Age&r and &6Copper Age&r chapters."
	]
