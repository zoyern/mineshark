		"&bRune Of Reinforcement&r increases Soul Ward capacity."
		""
		"Also improves Soul Ward integrity."
	]
	quest.650A06E7214A2ED1.quest_subtitle: "Stronger Soul Ward"
	quest.654073EFE6B79BCF.quest_desc: [
		"&aPros:&r"
		"&8●&r Saturation heals twice as fast"
		"&8●&r Heals three times as fast when near death"
		"&8●&r Increases healing received"
		""
