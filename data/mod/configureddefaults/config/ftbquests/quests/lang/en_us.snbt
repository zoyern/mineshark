	]
	quest.3CB6FAB718198DE7.quest_subtitle: "Fortune of the sea"
	quest.3CCB559BCAB1B69C.quest_desc: [
		"The &bShielding Apparatus&r uses &bSoulstained Steel&r to reinforce the process."
		""
		"It gives a chance to completely absorb damage to the Impetus."
		""
		"It slightly reduces Crucible instability."
		""
		"Focusing speed is reduced in exchange."
	]
	quest.3CCB559BCAB1B69C.quest_subtitle: "Protect the Impetus"
	quest.3CD1A691BB9D92B1.quest_subtitle: "Yee Haw!"
	quest.3CE5551031D8BB4D.quest_desc: ["Displays the current quantity of a specific resource contained in the storage setup."]
	quest.3CEBEFF81FF279FE.quest_desc: ["Improve slot for thread upgrade, high utilities and mana regen."]
	quest.3CEBEFF81FF279FE.title: "Apprentice"
	quest.3CFA567B98856D6F.quest_desc: ["Some of the Villagers seem to have taken a liking to you and are willing to join you, if you'd like to establish your own town. Take good care of them and I'm sure your town will attract many more Villagers."]
	quest.3CFA567B98856D6F.quest_subtitle: "Trade with Villagers to get rewarded!"
	quest.3CFA567B98856D6F.title: "Trading with Villagers III"
	quest.3D0087322543B31D.quest_desc: [""]
	quest.3D0087322543B31D.quest_subtitle: "Augmenting material"
	quest.3D1C0F80B74B27D5.quest_subtitle: "Arrive at a Lighthouse"
	quest.3D40D539C72FEE73.quest_desc: [
		"The &bRunewood Obelisk&r speeds up the &6Spirit Altar&r."
		""
		"Place up to four near the altar."
		""
		"Each obelisk increases infusion speed by 25%."
		""
		"Use them to reduce processing time."
	]
	quest.3D40D539C72FEE73.quest_subtitle: "Faster Spirit Infusion"
	quest.3D432C3BD00D8FF8.title: "Clockwork Village"
	quest.3D5973731CD4373C.quest_desc: ["{image:gamma_creatures:textures/screens/meloron_eng2.png width:150 height:100 align:center fit:true}"]
	quest.3D644B9C5CC46427.quest_subtitle: "Extra luck and increased block reach"
	quest.3D7EC35D193066EB.quest_desc: ["A book documenting the mod &dArs Nouveau&r. While the quest chapter &e\"The Basics of Magic\"&r will give you a good starting point, this book can help with any deeper questions about the mod and how to progress through it."]
	quest.3D7EC35D193066EB.quest_subtitle: "Detailed documentation on Ars Nouveau!"
	quest.3D7EC35D193066EB.title: "Worn Notebook"
	quest.3D8BCCFCEFEA77BE.title: "Highland Fields"
	quest.3D9C95CE885F5BA8.quest_desc: ["Kill 4 &5Endermite&r."]
	quest.3DA151EFD73220F6.quest_desc: [
		"Born from the legend of the Headless Horseman, &6Lord Pumpkinhead&r has vowed to destroy any that summon him. Don’t rely on any covered bridges to escape, he’ll chase right on after you. And should you manage to dismount him from his horse, there are two more deadly phases of the fight. The head can survive without the body, but the body will perish should the head be destroyed. "
		"{@pagebreak}"
		"Lord Pumpkinhead can be summoned by r-clicking on the &6Infernal Evil Pumpkin&r using &aTransmuting Elixir&r."
	]
	quest.3DC0A0DC4DA66211.quest_desc: ["High tier book and can be use as endgame spell book after clear ancient city"]
	quest.3DC0A0DC4DA66211.title: "Codex Expert"
	quest.3DD5EBA72E439D1E.quest_desc: ["To fill a chunk loader, r-click a ghast with it in your hand. An andesite chunk loader will load a single chunk."]
	quest.3DD5EBA72E439D1E.title: "Andesite Chunk Loader"
	quest.3DE866DDF6CA85FD.title: "Tree of Wisdom"
	quest.3E07D228EA16C682.quest_desc: [
		"As you hand over the &5Note&r to the receptionist, she smiles brightly and asks,"
		""
		"&b\"What would you like?"
		""
		"&aFortune?&r"
		"&2Power?&r"
		"&bPrecious Gems?&r"
		"&6Food?&r"
		"&3Experience?&r"
		"&bor perhaps, more &5Bounties and more adventures?&r&b\""
	]
	quest.3E07D228EA16C682.quest_subtitle: "Redeem the Guildmasters Note for Rewards!"
	quest.3E07D228EA16C682.title: "Trade: Guildmasters Note for Rewards"
	quest.3E6F275611819111.quest_desc: [
		"&6Mechanical Belts&r move rotational power between Shafts and can also carry items or entities along their length."
		""
		"To place a belt, start with at least two &6Shafts&r."
		"Right-click the first Shaft, then the second to connect them."
		"Only one belt item is used, no matter how long the connection is."
		""
		"Belts can connect Shafts arranged horizontally, vertically, or diagonally."
		"The maximum distance between them is &620 blocks&r, and the path must be clear."
		""
		"&6Andesite Casing&r or &6Brass Casing&r can be applied to belt segments for decoration."
	]
	quest.3E6F275611819111.quest_subtitle: "Power and item transport"
	quest.3E7C748B00FAB751.quest_desc: ["The hard part about this pack is many of the features are so integrated that it's hard to untangle them. That said, many are highly configured (looking at you, Apotheosis...) to smooth some of the rougher corners. &bWe are willing to help you remove mods if you ask in Discord&r (besides Ars Nouveau, Create, and a few others. Those are bedrock of this pack unfortunately)."]
	quest.3E855ADF431DCB49.quest_desc: [
		"&aPros:&r"
		"&8●&r Mining explosions yield additional drops"
		"&8●&r Explosive mining improves resource gain"
		""
		"&4Cons:&r"
		"&8●&r —"
		""
		""
		""
		"&8Pedestal Items:&r"
		"8x Blaze Powder"
		"4x Raw Gold"
		""
		"&8Central Item:&r"
		"12x Gunpowder"
		""
		"&8Spirits:&r"
		"16x &#FA9A1FInfernal&r"
		"16x &#48EE19Earthen&r"
		"16x &#EE2C88Sacred&r"
	]
	quest.3E855ADF431DCB49.quest_subtitle: "Engulf yourself with greed"
	quest.3EAB8449F3BAC667.quest_desc: [
		"The &6Cogwheel&r transfers rotational power."
		""
		"The &6Large Cogwheel&r allows more advanced setups, such as turning rotation around corners or connecting to a &6Rotation Speed Controller&r."
		""
		"Two &6Cogwheels&r placed next to each other rotate in opposite directions."
		""
		"Two &6Large Cogwheels&r placed perpendicularly transfer rotation to another axis without changing speed."
		""
		"A &6Cogwheel&r paired diagonally with a &6Large Cogwheel&r changes speed."
		"The large gear rotates at half the speed of the small one."
		""
		"By combining different sizes, rotation speed can be doubled or halved, up to &6256 RPM&r."
	]
	quest.3EAB8449F3BAC667.quest_subtitle: "Basic rotation transfer"
	quest.3ECA226F08D5195F.quest_desc: ["Hidden among hills and valleys, the monastery stands as a quiet refuge in a world of rising danger. Here, villagers tend to simple lives of prayer and work, untouched by Illager conquest. Though the halls hold little in the way of treasure, their sturdy walls and peaceful company make this an ideal sanctuary for weary adventurers."]
	quest.3ECA226F08D5195F.quest_subtitle: "Find a Monastery"
	quest.3F062C3715898E58.quest_desc: ["{image:gamma_creatures:textures/screens/dogishi_eng2.png width:150 height:100 align:center fit:true}"]
	quest.3F2E272663BECA1F.title: "Mott"
	quest.3FA36BF576843022.quest_desc: [
		"Frostmaws are rare, massive beasts of the snowy lands. Their &bice breath&r and immense strength make them deadly foes."
		""
		"If you find one sleeping on your path, it may be wiser to go around rather than wake it. The creature guards a precious &eIce Crystal&r, capable of unleashing pure winter energy when wielded. Ranged weapons are recommended for those daring enough to face it."
	]
	quest.3FC3D70076B6DDF0.quest_desc: [
		"This is a prehistoric beast possibly related to the &eAncient Remnant.&r But with both creatures being only made from fossils and too hostile to safely approach and study, archeologists have yet to determine an actual relation between the two. The &6Skeletosaurus&r uses its sheer strength and size to overwhelm its foes and kill its prey quickly. Sturdy feet and a spiky tail make great innate weapons. Should you slay this mighty beast, you might find yourself with a young one to care for and tame."
		"{@pagebreak}"
		"The Skeletosaurus can be discovered in various &6fossil sites&r and structures. "
	]
	quest.3FD44295355BD49B.quest_subtitle: "Stormline Ascension ability. Aqua and Lightning school bonuses"
	quest.3FD44295355BD49B.title: "Riptide Sovereign Armor"
	quest.3FED14D4D8B8C5DE.title: "Rainforest"
	quest.40133E6D438CF1D1.title: "Ancient Portal"
	quest.403944D482FBA961.quest_desc: ["Place down some train tracks and r-click them while holding a train station. A long, flat stretch of track is best. Open the train station's menu and select \"Create New Train.\" Place a train casing on any of the highlighted tracks to turn it into a bogey. From there, you can build off of the bogey and design your train. Make sure to use superglue to keep everything together. When you are done building, open the station's menu again and select \"Assemble Train.\" NOTE: You must have at least on train control on board."]
	quest.403944D482FBA961.title: "Building a Train"
	quest.404FF177CB141691.title: "Cottage"
	quest.40AD704CCE937072.quest_desc: [
		"The &6Rope Pulley&r moves contraptions vertically, often used for excavation or elevators."
		""
		"It can extend up to 256 blocks downward."
		""
		"Additional pulleys placed above the contraption will synchronize automatically and do not require their own rotational power."
		""
		"The rope length can be monitored using a &6Threshold Switch&r."
	]
	quest.40AD704CCE937072.quest_subtitle: "Vertical movement"
	quest.4106639299FA35BE.quest_desc: [
		"Once one of the six sea gods, &bScylla&r was cast out for breaking the divine law—she fell in love with &bMaledictus&r, a mortal king. When he gave his life to stop &6Ignis&r and save the world, her grief became her curse."
		""
		"She withdrew to a fortress high above the clouds, her sorrow twisting into rage. Immortal in body but shattered in mind, she now strikes down any human who dares to approach."
		""
		"Some say only a true hero can end her torment. Craft the &9Eye of Storm&r, locate &bthe acropolis&r and rise into the sky—where her endless sadness still lingers."
		"{image:kubejs:textures/quests/cataclysm/area_render.png width:100 height:100 align:center fit:true}"
	]
	quest.4118927D9D079DC8.quest_desc: ["Rising like jagged thorns from the ground, these massive towers are defended by skeletons entwined with deadly roses. Each level is heavily fortified, and flying rose guards patrol the skies above. Only those who ascend to the top will claim the treasures and secrets hidden within."]
	quest.4118927D9D079DC8.quest_subtitle: "Visit the Thornborn Towers"
	quest.411E75619F1C378C.quest_desc: ["Somehow killed &0Wither&r with &estinger spear&r."]
	quest.415CD6CC10D4D7F2.quest_desc: ["{image:gamma_creatures:textures/screens/redthunder_eng2.png width:150 height:100 align:center fit:true}"]
	quest.41A34FE87DD3EA6E.title: "Bastion"
	quest.41ACE04C5F44BBF1.title: "Sunken Ship"
	quest.41CD8B330FFD9CB1.quest_subtitle: "Increases mana amount and regen rate. Bonus spell power"
	quest.41CD8B330FFD9CB1.title: "Warlock Outfit"
	quest.41E311ABBAABFC87.quest_subtitle: "Increased attack knockback"
	quest.41FCDB46DA5FB7F6.quest_subtitle: "{components:{\"ftbquests:loot_crate\":\"relics\"},count:1,id:\"ftbquests:lootcrate\"}"
	quest.421DBFFF19DD7A4F.title: "Cabin Village"
	quest.424B875F88D10370.quest_subtitle: "I have two side!"
	quest.4281E238E86E010D.quest_desc: ["A white flower with roots that hold precious resin. Once crystallized, the resin can be blended into incense with subtle magical effects."]
	quest.4281E238E86E010D.quest_subtitle: "Hidden Resin"
	quest.42963ECC905690BB.quest_subtitle: "Complete all \"Suit Up\" Quest Chapters"
	quest.42963ECC905690BB.title: "Fashionista"
	quest.42A44816F5A597CF.quest_desc: ["{image:gamma_creatures:textures/screens/turlan_eng2.png width:151 height:100 align:center fit:true}"]
	quest.42D011E0D00103A4.quest_desc: ["Use with a &eNetwork Receiver&r and a &eNetwork Card&r to transmit between storage networks wirelessly. "]
	quest.42ED72476B62BA71.quest_desc: ["&5Mage's Spell Book&r allow you to cast tier 2 glyphs and below"]
	quest.42FA5AE8D5124F92.quest_desc: [
		"The Wither’s power drew the interest of &9technomancers&r, who sought to turn it into a weapon. They captured and reshaped it into the Harbinger—a mechanical war machine. But a shard of its &8tormented soul&r remained, beyond control."
		""
		"Countless lives were lost before its &eNether Star&r core was removed and the project abandoned. The ruined factory now lies buried beneath the earth, hidden from sight."
		"To locate it, one must wield the &6Eye of Mech&r—the only device able to detect what still stirs below."
		"{image:kubejs:textures/quests/cataclysm/the_harbinger.png width:100 height:100 align:center fit:true}"
	]
	quest.4304895AF86DC805.quest_desc: ["After basic equipment this is tougher. Allow you to survive hit with less dmg taken."]
	quest.4304895AF86DC805.title: "Upgraded Diamond"
	quest.430F86987CE5238E.quest_subtitle: "Increases magic resistance and mana"
	quest.430F86987CE5238E.title: "Silver Armor"
	quest.4353E25AA0DCDB58.quest_subtitle: "&l&n&5Legendary Ice blacksmith's hammer once forged the greatest of weapon's!"
	quest.436231715C11E3BA.quest_desc: ["Scattered across the wilds, small bands of Illagers set up camp beneath their distinctive purple tents. Though their supplies are meager and their loot scarce, their presence is a warning, the Illagers’ reach grows wider with every outpost."]
	quest.436231715C11E3BA.quest_subtitle: "Find an Illager Campsite"
	quest.4378B90E9375D1CD.quest_desc: [
		"&#6EC1FFSimple Rite&r"
		""
		"While active, it extinguishes nearby creatures and grants Fiery Embrace."
		"This blessing provides passive healing."
		""
		"[  ]"
		"[  ]"
		"[&#72EE19✧&r] &#72EE19Earthen&r"
		"[&#72EE19✧&r] &#72EE19Earthen&r"
		"[&#D546FF✧&r] &#D546FFArcane&r"
	]
	quest.4378B90E9375D1CD.quest_subtitle: "Fire that heals"
	quest.43935D97BB3B38D1.quest_subtitle: "Wall-climbing ability"
	quest.439FFB4A65551718.quest_desc: ["A true support will hold this and never fall down"]
	quest.439FFB4A65551718.title: "In the name of Holy "
	quest.43AE9F7F76FCA7A7.quest_desc: [
		"&bRune Of Flowing Grasp&r slightly increases block interaction range."
		""
		"Also increases item pickup range."
	]
	quest.43AE9F7F76FCA7A7.quest_subtitle: "Extended reach"
	quest.43DF5901292EE06B.quest_desc: ["Simple reforging table allow you to forge up to blue affix item and below"]
	quest.43F2C4EC814D8533.quest_subtitle: "Recall - but with friends"
	quest.442B3A81C8E4329E.title: "Windswept Hills"
	quest.445F34F5990BBEFE.quest_subtitle: "A faint power flows out from the mask. Perhaps if you find more, you can find where it leads..."
	quest.445F34F5990BBEFE.title: "Secret of the Masks"
	quest.446D0100403541F3.quest_desc: ["{image:gamma_creatures:textures/screens/golemd_eng2.png width:151 height:100 align:center fit:true}"]
	quest.4495444D3F04CFC2.quest_desc: [
		"Unfortunately, you died. Luckily, I could bring you back. However, all of your equipment is stored in a &aGravestone&r at your place of death. "
		""
		"Break it to get your items back!"
		""
		"You also have an &aobituary&r with the coordinates of your death."
	]
	quest.4495444D3F04CFC2.quest_subtitle: "Recover your supplies"
	quest.4495444D3F04CFC2.title: "Post-Mortem"
	quest.449DCB90268523CD.title: "Mossy Mounds Village"
	quest.44D115281B0BFB75.quest_desc: ["Whispers speak of a &9flying vessel&r that hovers above the world, shimmering with strange energy. Few dare approach, for those who return tell of eerie lights, warped corridors, and guardians not of this realm. Seek it out, if you dare—and uncover the secrets hidden within its metallic shell."]
	quest.44D115281B0BFB75.quest_subtitle: "Find a Giant Mushroom"
	quest.44DE680409A4B3AE.quest_subtitle: "Teleport to friend"
	quest.44DE680409A4B3AE.title: "Tablet of Assistance"
	quest.44EF89410D2E3E0A.title: "Spires"
	quest.452903524040F904.title: "&2★☆☆ Tongbi, the Sculpter"
	quest.452F1882CA396798.quest_desc: ["{image:gamma_creatures:textures/screens/bear_eng2.png width:150 height:100 align:center fit:true}"]
	quest.453B7B49B55B952B.title: "Redhorn Guild"
	quest.453D1F9C959630C3.quest_desc: ["Complete green &2Sempiternal Sanctum&r challenge."]
	quest.4559CA5E4634C661.title: "Dark Tower"
	quest.45C92BD615F3B7EB.quest_desc: [
		"Once a mortal, &cIgnis&r was feared for his relentless experiments on life itself. He twisted his own body for forbidden power and used countless innocents as test subjects. Those he oppressed eventually rose and banished him to the Nether."
		""
		"In exile, he forged terrible weapons using &cMonstrosity&r, including a sword of explosive magic and a shield of eternal flame. When humans opened the Nether portal, he returned, seeking vengeance—but was ultimately defeated alongside &6Maledictus&r."
		""
		"Yet his soul endured, trapped in the &4Burning Ashes&r. To end his terror, all Ashes must be placed upon the &5Altar of Fire&r, destroying his final soul. The &9Eye of Flame&r will guide you to his rebirth—cleanse this abomination and prevent future disaster.f"
		"{image:kubejs:textures/quests/cataclysm/ignis.png width:100 height:100 align:center fit:true}"
	]
	quest.45C94A869977DDC6.title: "Lush Caves"
	quest.45E2C787B0B44DAF.quest_subtitle: "{count:1,id:\"refinedstorage:1024b_fluid_storage_block\"}"
	quest.45F1AE33BF507492.quest_desc: [
		"A wandering familiar devoted to the study of magic."
		"It specializes in manipulating simple spellcraft and interacting with arcane artifacts."
		""
		"&9Abilities:&r"
		""
		"• Can transmute spell scrolls placed on a pedestal.&r"
		"Creates a random scroll of the same rarity."
		"Small chance to produce a higher rarity scroll."
		""
		"• Endermen fear its presence and will flee.&r"
		""
		"• Can counter incoming Shulker bullets.&r"
		""
		"&dHabitat:&r"
		""
		"Sometimes found wandering the &5End,&r studying the limits of existence"
	]
	quest.45F1AE33BF507492.quest_subtitle: "Arcane Scholar"
	quest.45F1AE33BF507492.title: "Archmage"
	quest.45FE1ED838D186A9.quest_desc: [
		"The &6Fluid Tank&r stores fluids, holding up to 8 buckets (8000 mB) per block."
		""
		"Tanks connect with adjacent tanks to form larger multiblock structures, up to 3×32×3."
		""
		"Fluids can be inserted or extracted using &6Fluid Pipes&r from any side."
		""
		"The glass window can be toggled with a &6Wrench&r."
	]
	quest.45FE1ED838D186A9.quest_subtitle: "Fluid storage"
	quest.461A0A84153977E9.quest_desc: [
		"As you approach the tent, a woman covered in dirt and sand waves out to you."
		""
		"&b\"Greetings! It's nice to see another friendly face.\""
		""
		"&b\"With my work, I don't get to talk to people much. The name's &5Nico&r&b. I'm an &7Archeologist&r&b, seeker of truth, adventurer of ruins, and... I guess a woman covered in mud, dirt, and grime. Pleased to meet you.\"&r"
		""
		"&b\"&6If you share our passion for archeology, I can give you a map to the digsite we are currently working on&r&b. Unfortunately, we don't make a lot of money so &6a couple of emeralds&r&b would go a long way to securing you that map and me more food!\""
	]
	quest.461A0A84153977E9.quest_subtitle: "A Weathered Tent stands before you..."
	quest.461A0A84153977E9.title: "Archeology Camp"
	quest.462A48769DA1F114.quest_subtitle: "&l&n&5A sword lushed from the jungle!"
	quest.46334E21D0446EC0.quest_desc: ["You can Upgrade Basic Chest/Barrel straight into Netherite Tier. Same with Gold/Iron and so on."]
	quest.468A4AA02E32A08B.quest_subtitle: "{components:{\"ftbquests:loot_crate\":\"create\"},count:1,id:\"ftbquests:lootcrate\"}"
	quest.468FDF7394357FF3.title: "Ruins of the Deep"
	quest.46913E9659C71457.quest_subtitle: "&l&n&5Double edge weapon &efrom the stars!&r"
	quest.46B9E8C825098695.quest_desc: [
		"Cooking better food will greatly help you on your journey."
		""
		"Nourishing meals can increase your hearts and keep you satiated much longer, regardless of work or health regeneration."
		""
		"It is well worth automating."
		""
		"Unlocks &6Culinaery Arts&r chapter."
	]
	quest.46B9E8C825098695.quest_subtitle: "Increase your hearts"
	quest.46B9E8C825098695.title: "Cooking Basics"
	quest.46DD0C741220A8F1.quest_desc: [
		"A balanced familiar infused with frost magic."
		""
		"&9Abilities:&r"
		""
		"• Freezes water beneath itself and its owner, allowing them to walk across it."
		""
		"• Grants immunity to freezing, including powder snow."
		""
		"&dHabitat:&r"
		""
		"Often found wandering &bcold and icy&r biomes."
	]
	quest.46DD0C741220A8F1.quest_subtitle: "Child of Winter"
	quest.46DD0C741220A8F1.title: "Frostling"
	quest.46F9C994682774D9.quest_desc: [
		"A musical familiar that channels magic through sound and rhythm."
		""
		"&9Abilities:&r"
		""
		"• Plays melodies that brighten the journey of nearby adventurers."
		""
		"&dCreation:&r"
		""
		"Cast a &bsound-based spell&r near an untamed familiar to awaken its musical nature."
	]
	quest.46F9C994682774D9.quest_subtitle: "Melody Weaver"
	quest.46F9C994682774D9.title: "Bard"
	quest.4729C395E23EDB15.quest_subtitle: "Increases swim speed and enables gliding out of water"
	quest.472C8CBAF47579DD.title: "Dread Citadel"
	quest.474B713B22FBECB5.quest_desc: ["Use the &eBasin&r with the &eMechanical Mixer&r to mix ingredients, and hold liquids. Can also be used for shapeless crafting"]
	quest.4791FC0A2E834D85.quest_desc: ["Dark magics linger in the depths of these dungeons, woven into items, halls, and even the very air. Power awaits the bold, but so do twisted fates for the careless."]
	quest.4791FC0A2E834D85.quest_subtitle: "Find a Bathhouse"
	quest.47DD764C07B6E95E.title: "Evoker Fort"
	quest.48221B55DE4C5D0F.title: "Rocky Reef"
	quest.482E14A0544D2722.quest_desc: [
		"A King that died long ago…A maze to store his treasures and body…The &4Dead King&r can be found in the Throne Room of the &cCatacombs&r and awakened by interacting with him. A powerful mage, he poses a large challenge, though you will receive treasures beyond compare if you defeat him. Be warned…this may not be the last you see of the &4Dead King&r."
		"{@pagebreak}"
		"The &cDead King’s Catacombs&r can be located using the &6Wayward Compass&r."
	]
	quest.483EDF747257E7DB.title: "Warped Forest"
	quest.484D9BC7BEF1C300.quest_desc: ["Faster cast spell, every mage need this."]
	quest.48615BD4A9FCDDF1.quest_subtitle: "Seismic Ward ability. Nature school bonus."
	quest.48615BD4A9FCDDF1.title: "Primordial Crest Armor"
