	quest.0B997F9AA39276A1.quest_desc: [
		"The &bElaborate Brooch&r allows necklaces to be worn in belt slots."
		""
		"It removes normal slot limitations."
		""
		"Use it to combine accessories more freely."
	]
	quest.0B997F9AA39276A1.quest_subtitle: "Break slot restrictions"
	quest.0BB53AC414552D70.quest_desc: ["Attach to the refined storage system or an &eExternal Storage&r. Use in and out to fill items in &eDisk Drives&r. Specific items can also be filtered. Note: Ensure configurations in interface such as \"extract\" vs. \"insert\" are correct."]
	quest.0BB53AC414552D70.quest_subtitle: "Burning CD's!"
	quest.0BBFE3A82C1D7086.quest_desc: [
		"&cRawwrh!&r"
		""
		"Dragons have 5 stages. The ones on the surface are stages 2 and 3. The ones underground are stages 4 and 5. The bigger the dragon, the higher the stage and more difficult the fight. They have been placed under Tier 3 in the Boss Codex since that is middle-of-the-road."
		""
		"&7TIP: Dragon Eggs only drop from stage 4 and 5 &efemale&7 dragons."
		"{@pagebreak}"
		"Fire Dragons can be found in hot biomes such as deserts and mesas."
	]
	quest.0C2CAC4A102542B9.quest_desc: ["{image:gamma_creatures:textures/screens/crasu_eng2.png width:150 height:100 align:center fit:true}"]
	quest.0C2CB07683B598AB.quest_desc: [
		"There are many &6Backpack Upgrades&r that can improve capacity and add new functions."
		""
		"For example, the &6Stack Upgrade&r increases the number of items that fit in a single slot 1.5x times."
		"Higher tiers can increase this even further."
		""
		"Check &6EMI&r to see all available upgrades."
		""
		"Be careful not to confuse &6Backpack Upgrades&r with &6Storage Upgrades&r."
	]
	quest.0C2CB07683B598AB.quest_subtitle: "Expanding Functionality pt.2"
	quest.0C2CB07683B598AB.title: "Backpack upgrades"
	quest.0C3DFDEB587C59F6.quest_subtitle: "Set foots to The End"
	quest.0C54493D1D9C9372.quest_subtitle: "Witch haggling capability. Increases magic attack damage and magic resistance"
	quest.0C54493D1D9C9372.title: "Witch Outfit"
	quest.0C5695A1133DF90F.quest_desc: ["{image:gamma_creatures:textures/screens/bee_eng2.png width:150 height:100 align:center fit:true}"]
	quest.0C629DD47BACD841.quest_desc: ["Trade &bNether Rubies&r for &bPathfinder Quills&r to locate different biomes in the &cNether&r!"]
	quest.0C629DD47BACD841.title: "Finding Nether Biomes"
	quest.0C7809E3A8D4DD37.title: "Spell Power"
	quest.0C89CA8F21149A69.title: "Mortem Armor"
	quest.0CC80243EB0A36FA.quest_desc: [
		"The &6Scroll Forge&r is used to craft spell scrolls."
		""
		"Use &bInk&r, &fPaper&r, and a &eFocus&r to create a scroll."
		""
		"&bInk&r determines the rarity and level of the scroll."
		""
		"&eFocus&r determines the school of magic the scroll belongs to."
	]
	quest.0CC80243EB0A36FA.quest_subtitle: "Craft Spell Scrolls"
	quest.0CC80243EB0A36FA.title: "Scroll Forge"
	quest.0CDACDDD6BDF6D67.quest_subtitle: "Increases mana and hearts. Evocation school bonus"
	quest.0CDACDDD6BDF6D67.title: "Bone Paladin"
	quest.0CE2E4ABA84D5CF2.quest_desc: ["A brand new quest chapter all about the farming and cooking options within &5Integrated Minecraft!&r Don't worry, it will include important information on the food book and earning extra hearts."]
	quest.0CE2E4ABA84D5CF2.title: "Cooking and Farming"
	quest.0CE50A7F4F1A0E4D.quest_desc: ["ladder stretches skyward, disappearing into the clouds. At its top floats a strange, floating vessel. What secrets or dangers await above, none can say… except that the view alone is enough to make even the bravest adventurer’s stomach turn."]
	quest.0CE50A7F4F1A0E4D.quest_subtitle: "Find a Small Blimp"
	quest.0CE795753D85E42B.quest_desc: ["{image:gamma_creatures:textures/screens/tiburon_eng2.png width:150 height:100 align:center fit:true}"]
	quest.0CEC4FEFF915FD6F.title: "Ignitium Armor"
	quest.0D021946F6D1036A.quest_desc: ["Used to pack, press, and compact, this machine can be used to make metal sheets, an essential item to craft other Create items. "]
	quest.0D1779E491ED8A2F.quest_desc: [
		""
		"{@pagebreak}"
		"(new page placeholder text)"
	]
	quest.0D1779E491ED8A2F.title: "Mineshaft"
	quest.0D47283F9CB3D318.title: "Fields"
	quest.0D48392967F9000B.quest_desc: ["{image:gamma_creatures:textures/screens/bear_eng2.png width:151 height:100 align:center fit:true}"]
	quest.0D534B3FB957F5AA.quest_desc: ["{image:gamma_creatures:textures/screens/shecko_eng2.png width:150 height:100 align:center fit:true}"]
	quest.0D9387765E15B6E6.title: "Bearclaw Inn"
	quest.0DA7B652CC5FD89A.quest_desc: ["{image:gamma_creatures:textures/screens/grudels_eng2.png width:151 height:100 align:center fit:true}"]
	quest.0DC4960C79EC8367.quest_desc: ["Use with a &eNetwork Transmitter&r to connect storage networks wirelessly. "]
	quest.0DCE59A1FBCF1519.quest_subtitle: "Brief flight capability when in darkness"
	quest.0DCE59A1FBCF1519.title: "Darkness Suit"
	quest.0DE14E15D9A336F6.quest_desc: [
		"A monster with one body and six…no three…no nine heads. The &aHydra&r makes its lair in &2swampy&r biomes. The fog helping it to sneak up on and poison its prey. This creature will attack anything that moves, so you better hope it’s not got its sights set on you. If it does, make sure to keep it alight with fire, so that its heads do not multiply."
		"{@pagebreak}"
		"The &aHydra&r will spawn in its lair throughout &2swamp-like&r biomes."
	]
	quest.0E21C7219714B8A7.quest_desc: [
		"As you approach the Redhorn Guild, you hear the rattle of weapons and armor as its inhabitants stare at you through the tower. Once you pull out the &5Note&r, though, everyone settles back down and you are waved inside."
		""
		"There, you meet an older man, with dark hair and an eyepatch over one eye. Around his neck lies a necklace, holding a slowly blinking red &5Eye&r. "
		""
		"&b\"Thank you for making the long journey here. My name is &5Craisin&r&b, and I am the current guildmaster. I often send note out to those who are &6Reputable&r&b and have accomplished many great things on behalf of the &5Guild&r&b.\""
		"{@pagebreak}"
		"&b\"Now that I've gotten to meet you in person, we can officially register you with the &5Guild&r&b. Just sign this &5Contract&r&b here.\""
		""
		"After you sign the &5Contract&r, it is set ablaze by sparkling blue and purple flames."
		""
		"&b\"Perfect! Since some of our &6Quests&r&b require &5Guildmembers&r&b to slay monsters deep in the caves, the &5Contract&r&b acts as a means of verifying the completion of those &6Quests&r&b without requiring the &5Guildmembers&r&b to fork over some of the spoils.\""
		""
		"&b\"Now that you've registered, you can also turn in the &5Note&r&b at the Counter over there for rewards. I often send &5Reward Notes&r&b to any &6Bounty Board&r&b with a high rate of completion, so if you earn more, you're more than welcome to come back and trade them for more goods.\""
	]
	quest.0E21C7219714B8A7.quest_subtitle: "Find the Guild!"
	quest.0E21C7219714B8A7.title: "The Redhorn Guild"
	quest.0E27BB345555B163.quest_desc: ["Details and flavorful descriptions of all the mobs from &6\"Alex's Mobs\"&r!"]
	quest.0E27BB345555B163.quest_subtitle: "Click to get the Animal Dictionary!"
	quest.0E3EF6B800C9AD0D.title: "Eucalyptus Forest"
	quest.0E920B47FE1D61F2.title: "Frozen Peaks"
	quest.0EABC471B5A4422B.quest_desc: ["{image:gamma_creatures:textures/screens/gusnow_eng2.png width:151 height:100 align:center fit:true}"]
	quest.0EBC45A74B6F6BBF.quest_subtitle: "&l&n&5Once a old relic but was blessed by the gods!"
	quest.0EECD33C8D3B683F.quest_subtitle: "Reach lv1000"
	quest.0EECD33C8D3B683F.title: "At the place called \"MAX\""
	quest.0F0860DB98A76334.quest_desc: ["{image:gamma_creatures:textures/screens/bee_eng2.png width:151 height:100 align:center fit:true}"]
	quest.0F3AF3760EEF1B76.quest_desc: ["The ruler over the entire End dimension, the &5Ender Dragon&r acts as a gatekeeper for any adventurers who step foot in her dimension. She is a mighty beast who protects her land, but often overlooks her harm of the other End residents. Once you travel to the End, the &5Ender Dragon&r is the only thing standing between you and returning home to the Overworld."]
	quest.0F47194D1B1B9873.quest_desc: [
		"The &6Experience Lantern&r absorbs experience from nearby players and experience orbs."
		""
		"It glows based on the amount of stored experience."
		""
		"The lantern also works on &6contraptions&r."
	]
	quest.0F47194D1B1B9873.quest_subtitle: "Experience storage"
	quest.0F9318C32E0B74F6.quest_desc: [
		"&2Cyclopes&r are a species of one-eyed giants. Filled with a love for sheep and a hatred for humans, they stay in caves watching over their flocks. You may occasionally see one taking a stroll with their flock of sheep out in the plains. Brute force is their strength while vision is their weakness. It is said that an accurate shot towards its eye can leave the &2Cyclops&r blinded and stunned."
		"{@pagebreak}"
		"&2Cyclopes&r are most often found in their &7stoney coves&r along &ebeaches&r, but occasionally can be spotted roaming &2plains&r and &2savannas&r."
	]
	quest.0FAB015603DE8044.quest_desc: [
		"The &bResonance Tuner&r combines &#4BF3DAAerial&r and &#48EE19Earthen&r forces."
		""
		"It reduces or eliminates Crucible instability."
		""
		"The process becomes slower in exchange."
		""
		"Less risk. More time."
	]
	quest.0FAB015603DE8044.quest_subtitle: "Stability over speed"
	quest.0FACEEEE34E36733.title: "Draco Arcanus Armor"
	quest.0FAFE1943A28AF86.quest_desc: [
		"Crafted by a mage piglin from ancient debris and black stone, the Nether Gauntlet was meant to be a living weapon. The piglin sacrificed its soul to merge with it, but lacking mana while trapped in the Nether, the Gauntlet remained dormant—just a heavy block of stone."
		""
		"It awakens only when provoked, and its compressed form makes it &cexplode&r upon defeat."
	]
	quest.0FD6AAFFD4876C36.quest_desc: ["{image:gamma_creatures:textures/screens/muba_eng2.png width:150 height:100 align:center fit:true}"]
	quest.0FE59C55B86FC83C.title: "Old Swampland"
	quest.10008913EA0470F6.quest_desc: [
		"Familiars are magical creatures that can be found throughout the world."
		"They can be tamed using &6Arcane Essence&r."
		""
		"Once tamed, they will follow you and fight using their own spells."
		""
		"Use the selection menu to manage your familiars."
		"Press &6H&r to open the menu."
		""
		"From there you can summon, unsummon, or release them."
		"After selecting a familiar, press &6X&r to summon or dismiss it."
		""
		"You can have up to &610 familiars&r at the same time."
	]
	quest.10008913EA0470F6.quest_subtitle: "Familiar pokeball"
	quest.103AA360532E952F.title: "Deciduous Forest"
	quest.103D3820A6270DC2.quest_desc: ["Ruler of the Dreadlands, the &bDread Queen&r uses her army to reign supreme over that icy and bitter dimension. But the Dreadlands has nothing left to conquer, and so she has turned her sights elsewhere. Now there are &bDread Citadels&r appearing in snowy lands across the Overworld. These looming structures house the &bDread Queen’s&r army, and in the throne room, the &bDread Queen&r herself."]
	quest.10597BEDC2D04D62.quest_subtitle: "Increases speed"
	quest.10597BEDC2D04D62.title: "Gingerbread Outfit"
	quest.109C6AD5357E8B22.quest_desc: [
		"There are several &bSecret Recipes&r within &6Integrated Minecraft&r. To find these recipes, go exploring and discover new structures and dungeons with recipe books inside. Many of the recipe books are intentionally left ambiguous with the intent that players puzzle it out on their own. "
		""
		"That said, we know not everyone likes that approach. Thus, each quest book &oshould&r trigger a &5Quest&r containing an exact image of the process along with a written description of materials needed."
	]
	quest.10A8E96044487FDE.quest_desc: [
		"&aPros:&r"
		"&8●&r Half of incoming damage is buffered as damage over time"
		"&8●&r Buffered damage cannot kill you"
		""
		"&4Cons:&r"
		"&8●&r Buffered damage becomes stronger magic damage over time"
		""
		""
		"&8Pedestal Items:&r"
		"8x Prismarine Shard"
		"8x Prismarine Crystals"
		"8x Copper Ingot"
		""
		"&8Central Item:&r"
		"Heart Of The Sea"
		""
		"&8Spirits:&r"
		"32x &#1D64E8Aqueous&r"
		"32x &#EE2C88Sacred&r"
		"16x &#48EE19Earthen&r"
		"16x &#CB0CF8Eldritch&r"
	]
	quest.10A8E96044487FDE.quest_subtitle: "A warped echo"
	quest.10AB987481CCF81A.quest_subtitle: "&l&n&5Once a spear of a arcane wizared seems to be imbued!"
	quest.10AFE0DCD77A8E66.quest_desc: [
		"As you talk with the Fisherman, he mentions"
		""
		"&b\"Honestly, while I do fish partly to survive, I love seeing rare and unique fishes. I keep a journal with all of the ones I've encountered.\""
		""
		"&b\"My dad, the one who taught me how to fish, once spoke of a rare fish that can only be found in &6a few small portion of the world&r&b. Sounds like a myth, but wouldn't it be cool if that was the case? I'd love to see them sometime.\""
		""
		"&o(Hint on next page)&r"
		"{@pagebreak}"
		"Hint: &eCachalot Whales and Slime Balls&r"
	]
	quest.10AFE0DCD77A8E66.quest_subtitle: "Never before seen Fish"
	quest.10AFE0DCD77A8E66.title: "Rare Fish?"
	quest.10CEE4A6CA64EB43.quest_desc: ["{image:gamma_creatures:textures/screens/pangolin_eng2.png width:150 height:100 align:center fit:true}"]
	quest.10EC9FF38EB45AC1.title: "Barley Fields"
	quest.11263C23054F75DA.quest_desc: [
		"&bRune Of Oaken Might&r grants Oaken Might at half strength."
		""
		"Improves survivability and physical resilience."
	]
	quest.11263C23054F75DA.quest_subtitle: "Enduring strength"
	quest.112A82ADF7733058.quest_desc: ["The &6Mechanical Drill&r breaks the block directly in front of it when supplied with rotational power."]
	quest.114347412B7B12D4.quest_desc: ["A &eGrid&r with the ability to craft."]
	quest.114534F59500DF73.quest_desc: [
		"Every journey begins with a simple chest."
		""
		"As you progress and gather more materials, storage quickly becomes a real challenge."
		""
		"Unlocks &6Basic Storage&r chapter."
	]
	quest.114534F59500DF73.quest_subtitle: "Hoard the items"
	quest.114534F59500DF73.title: "Storage Basics"
	quest.118D168C5F04C4AA.quest_desc: [
		"&aPros:&r"
		"&8●&r Food grants increased saturation"
		"&8●&r Eating food cleanses negative effects"
		""
		"&4Cons:&r"
		"&8●&r Low hunger drains health much faster"
		""
		""
		"&8Pedestal Items:&r"
		"8x Salmon"
		"2x Nautilus Shell"
		""
		"&8Central Item:&r"
		"12x Prismarine Crystals"
		""
		"&8Spirits:&r"
		"16x &#1D64E8Aqueous&r"
		"16x &#EE2C88Sacred&r"
	]
	quest.118D168C5F04C4AA.quest_subtitle: "Eat, lest your body consume itself"
	quest.11C8A5470DB1E379.quest_subtitle: "Pacifies Froststalkers"
	quest.11D09E5F4AB40491.title: "Mauve Hills"
	quest.11D177A5EC76419A.title: "Basalt Delta"
	quest.11EB9691A5A1E0C0.quest_desc: [
		"As you approach the lodge stationed above the waves, a bearded man holding a fishing rod excitedly greets you!"
		""
		"&b\"Hello hello, fellow fishing enthusiast. I'm glad my message reached you! It's been several years since I've started sending them out and I was starting to lose hope.\""
		""
		"&b\"Well please, come in. Here, have some &6Fish Stew&r&b. And help yourself to anything in here. It's all fishing related, but I love supporting fellow enthusiasts.\"&r"
	]
	quest.11EB9691A5A1E0C0.quest_subtitle: "A Rickety Shack lies on top the Water"
	quest.11EB9691A5A1E0C0.title: "The Fishermans Lodge"
	quest.120118A64B3F7444.title: "Pine Taiga"
	quest.122CCB3EA2A7E761.quest_desc: ["These items can be imbued with spells that will be triggered on use. The imbued equipment is powerful and should be used in combat."]
	quest.122CCB3EA2A7E761.title: "Magical Equipment"
	quest.128B578BED657EC1.quest_desc: ["You can't be an archer without this."]
	quest.128B578BED657EC1.title: "Yes Bow"
	quest.129F249D83E29FDC.quest_desc: ["Runewood's charcoal, as magic-infused as it is, burns with an arcane fervor for longer than regular charcoal."]
	quest.12AB4E279945B4B9.quest_desc: ["{image:gamma_creatures:textures/screens/lennat_eng2.png width:151 height:100 align:center fit:true}"]
	quest.12AB8BFCFE89CE4F.quest_desc: ["Complete purple &5Sempiternal Sanctum &rchallenge."]
	quest.131B6DE8B6402E75.title: "Autumnal Maple Forest"
	quest.1351DAD5382158BE.title: "Abandoned House"
	quest.13A45A91408CDEA7.quest_desc: [
		"The &bGlass Brooch&r allows you to inscribe additional runes."
		""
		"It grants two extra rune slots."
		""
		"In exchange, it reduces your maximum health."
		""
		"Stronger runic setups require sacrifice."
	]
	quest.13A45A91408CDEA7.quest_subtitle: "Power at a cost"
	quest.142AF4495057C80E.title: "Mycotoxic Undergrowth"
	quest.1456087643099DEB.quest_subtitle: "Protection against dragon breath attacks"
	quest.1456087643099DEB.title: "Dragon Scale Armor"
	quest.146E343B2E98B082.quest_desc: [
		"A familiar attuned to the power of lightning and storms."
		""
		"&9Abilities:&r"
		""
		"• Temporarily charges the owner, granting increased speed and strength."
		""
		"• Seeks out creepers and attempts to charge them with lightning."
		""
		"&dHabitat:&r"
		""
		"Often found wandering &8mountain peaks&r, searching for lightning storms."
	]
	quest.146E343B2E98B082.quest_subtitle: "Storm Caller"
	quest.146E343B2E98B082.title: "Lightning Mage"
	quest.14739743674C8418.quest_desc: [
		"The &6Hose Pulley&r lowers a hose to drain or fill large bodies of fluid."
		""
		"When powered with rotational force, the hose extends downward."
		"Reversing the rotation retracts it."
		""
		"A &6Mechanical Pump&r is required to move fluid through the hose."
		""
		"If the fluid body contains at least 10,000 fluid blocks, it is treated as an infinite source."
	]
	quest.14739743674C8418.quest_subtitle: "Large fluid extraction"
	quest.14857DBF1DCBF100.quest_desc: ["Cresting the waves like a shadow of the past, this cursed vessel is crewed by skeletons that seem impossible to keep down. Every deck hides danger, every hold whispers of lost treasure and every strike you land may be fleeting. Only the bold (or the foolhardy) dare to face its relentless undead crew."]
	quest.14857DBF1DCBF100.quest_subtitle: "Find an Undead Pirate Ship"
	quest.148FFF736E641B8E.title: "Cursed Pyramid"
	quest.14BA1AFBE5DA8D59.quest_desc: [
		"A void being of unknown origin, the &5Obsidilith&r calls the End its home. It lives at the top of a large, cubic structure that floats in the void. Some think that this is to make it easier for the &5Obsidilith&r to defend its home. After all, not many creatures can survive in nothingness."
		"{@pagebreak}"
		"The &5Obsidilith&r can be spawned by placing an Eye of Ender into the Obsidian Altar at the top of the &5Obsidilith Arena&r."
	]
	quest.14F306621CDFE316.title: "REMEMBER ALEX BIOMES"
	quest.1553EAB6E1821554.quest_desc: [
		"Mechanical arms can move items between inventories as long as the inventory is \"open\" (belt, depot, funnel) and not \"closed\" (vault, chest, barrel). Input and output locations must be set before placing down the mechanicall arm. To do this, r-click once on the desired output inventory and r-click twice on the desired input inventory. There can be multiple input and output locations as long as they are within reach of the arm. "
		""
		"These arms cannot filter items themselves, but will follow the filters of brass funnels listed as input locations. This works especially well when paired with a mechanical crafter."
	]
	quest.15CBD80EF6E59C66.quest_desc: ["Train signals help control the flow of traffic for trains not driven by a player. To use one, hold it and r-click a track. Then place it nearby. Train signals have arrows pointing in the direction that trains are allowed to go. A signal can go both ways if a second train signal is placed on the other side of the track. For more information on the different settings and configurations of trainn tracks, use the ponder ability."]
	quest.15D67A707A499520.quest_subtitle: "Trade with villager 100 times"
	quest.15D67A707A499520.title: "Barter"
	quest.15E656AB2041D402.title: "Infernal Holt"
	quest.1685D64D1EDB0EB0.quest_desc: ["Allows to pipe items out of storage system."]
	quest.1689677166235C89.title: "Ashen Woodlands"
	quest.168FDCA29BFACC3D.quest_desc: [
		"The &6Blaze Forger&r works like an &8Anvil&r but uses &6Liquid Experience&r instead of repair cost."
		""
		"It can merge enchantments of the same item type and combine &6Enchanting Templates&r."
		""
		""
		""
		"&eExtract enchantments&r"
		"Place an enchanted item or book first."
		"Then add an &6Empty Enchanting Template&r."
		""
		"One random enchantment is removed and stored in the template."
		"Each template can hold only one enchantment."
		""
		""
		"&eApply enchantments&r"
		"Place the item first, then the enchanted book or template."
		""
		"Higher level enchantments may require &6Super Enchanting&r."
	]
	quest.168FDCA29BFACC3D.quest_subtitle: "Advanced enchanting"
	quest.16C70903BE6B120F.quest_desc: [
		"&aPros:&r"
		"&8●&r While submerged, increases agility, attack speed, mining speed and damage resistance"
		"&8●&r Conduit Power amplifies effects and restores health"
		""
		"&4Cons:&r"
		"&8●&r Cannot heal outside of water"
		""
		""
		"&8Pedestal Items:&r"
		"8x Prismarine Shard"
		"8x Prismarine Crystals"
		"8x Kelp"
		""
		"&8Central Item:&r"
		"Heart Of The Sea"
		""
		"&8Spirits:&r"
		"32x &#1D64E8Aqueous&r"
		"32x &#EE2C88Sacred&r"
		"16x &#4BF3DAAerial&r"
		"16x &#CB0CF8Eldritch&r"
	]
	quest.16C70903BE6B120F.quest_subtitle: "Become the ocean’s avatar"
	quest.1746CBB538290039.quest_desc: [
		"&5Special thanks to&r:"
		""
		"&eJAWredstoneguy&r, &eSlayDigger&r, &eChronicallyArden&r, &eAntN&r, and &earzadu&r for their work on the pack"
		""
		"&6Leafyyy&r for providing resources and help to the community"
		""
		"&dThe IDAS builder&r team for the fantastic structures"
		""
		"&1Pareidolia&r (Creator of Bibliophilia Resource Pack) for accepting mod suggestions to add to their resource pack"
		""
		"&aHeyKatu&r (Creator of Cottage Witch) for some of the pack's ideas&r"
		""
		"All of our wonderful players and discord members (esp. those who've brought bugs to our attention)"
		""
		"Sincerely,"
		"&5CraisinLord&r and &4Hisakid&r"
	]
	quest.174DA5B7870ACD56.quest_desc: [
		"The &5Void Worm&r is the result of a failed experiment to clone the &5Ender Dragon&r. Instead of a dragon, the experiment resulted in a hostile, worm-like creature that shoots through the sky and teleports around to throw its opponents off balance. The most dangerous part of the failed cloning experiment, perhaps, is that the &5Void Worm&r can clone itself. If shot anywhere except its head, the &5Void Worm&r will split in two at the wound."
		"{@pagebreak}"
		"&5The Void Worm&r can only be summoned if the &5Ender Dragon&r is already defeated. To summon the &5Void Worm&r, throw a &9Mysterious Worm&r into the void while in the End dimension."
	]
	quest.17621723674DC74B.quest_desc: [
		"The &bGluttonous Brooch&r reduces your effective satiation."
		""
		"You become hungry more often."
		""
		"In exchange, you gain an additional belt slot."
		""
		"More utility, but constant appetite."
	]
	quest.17621723674DC74B.quest_subtitle: "Trade hunger for space"
	quest.17687AC25D68E078.title: "Cryomancer Tower"
	quest.17B052A1D386EEA6.title: "Necromancer's Spire"
	quest.17D8D6C09A6BB039.quest_desc: [
		"&eUmvuthi&r is the creator of the &eAbavuthana&r, residing in a stationary seat upon a throne in savanna groves. He draws his power from the sun, calling forth sunstrikes, solar flares, and massive solar beams. He can also create Umvuthana followers - including healers called &eUmvuthana Cranes&r - from masks to defend him during combat. As such, his masked children revere him as a god. Unequipped travelers should keep their distance from his grove, lest they be smitten by his heliomancy."
		"{@pagebreak}"
		"Use the &6Eye of Sunbird&r to locate &eUmvuthani&r and his followers in the savanna."
	]
	quest.17EC541F5D610169.title: "Candy Cavity"
	quest.17EFC22034CD0363.title: "Abyssal Armor"
	quest.1846F5727D2BC433.quest_desc: ["Provides wireless access for certain Refined Storage items."]
	quest.1863CB73604AFD14.quest_desc: [
		"&bCulonimbus, the cloud golem, &ris an ancient &egod of air and thunder,&r He uses lightning and sky magic to protect his temple. As the antithesis to stone and earth, &eCulonimbus &rhas a hatred for any patron of these elements. The &2Ancient Guardian &ris the biggest enemy of them all. If &bCulonimbus&r sets his eyes upon the &2Ancient Guardian,&r he will go into battle immediately. Despite his large appearance, he is still light as air and quick on his feet. With a large amount of health as well, he truly is quite formidable. Although some of his attacks use a lot of energy and leave him, well…winded. "
		"{@pagebreak}"
		"Culonimbus lives in the Cloud Temple. He is found on the top floor in a circular room wide open to the skies. Use an&6 Eye of Air&r to locate it."
	]
	quest.188AAB5B74C6EAAE.quest_subtitle: "Discover an Infested Temple explorer map"
	quest.188E4567C4BE3267.quest_subtitle: "Complete All \"Automation\" Quest Chapters"
	quest.18A1CBAD12A8DB2A.title: "Poppy Fields"
	quest.18DD9F0F1C039C6B.title: "Ice Arena"
	quest.1907BED0AC5F6B2E.title: "Frozen Tundra"
	quest.1908239C58D071D5.quest_desc: [
		"Andesite Casing is used to craft many machines."
		"It does nothing on its own, but machines need it."
		"To craft it, right-click a stripped log with &eAndesite Alloy&r."
		"Make several. Most builds use more than one."
	]
	quest.1908239C58D071D5.quest_subtitle: "Base component for machines"
	quest.1908239C58D071D5.title: "Andesite Casing"
	quest.191867EE552F6F30.quest_desc: [
		"&bCthonic Gold&r is a rare metal found deep underground."
		""
		"It generates in the deepslate layer within gold veins."
		""
		"It looks similar to pyrite, but has the density of gold."
		""
		"Its properties make it useful for advanced arcane crafting."
	]
	quest.191867EE552F6F30.quest_subtitle: "Arcane-infused deep metal"
	quest.1924733E33E5CA71.title: "Lichen Caves"
	quest.19279448939BE238.quest_desc: [
		"Allows enchantments to be stored and later applied to an item."
		""
		"&6Only one enchantment can be stored at a time.&r"
	]
	quest.19279448939BE238.quest_subtitle: "Storing enchantments"
	quest.193E29B1A735FAC5.quest_desc: [
		"Primary arcana define the nature of spiritual power."
		"They shape how magic behaves and what it affects."
		""
		"&8●&r &#D546FFArcane&r — raw, undirected spiritual power."
		"Found in mages and beings tied directly to magic."
		"Used as a base for many infusions and rituals."
		""
		"&8●&r &#EE2C88Sacred&r — life, purity, vitality."
		"Found in holy, innocent, or life-aligned beings."
		"Common in healing and enhancement magic."
		""
		"&8●&r &#792CECWicked&r — corruption and destructive force."
		"Found in twisted or hostile beings."
		"Often used in offensive or soul-altering magic."
	]
	quest.193E29B1A735FAC5.quest_subtitle: "Core spiritual forces"
	quest.193E29B1A735FAC5.title: "Primary Arcana"
	quest.1966555A6D4B8AC1.quest_desc: ["Finding this structure underground opens possibility to morph items into other."]
	quest.1966555A6D4B8AC1.quest_subtitle: "Dark side of magic"
	quest.1966555A6D4B8AC1.title: "Find Weeping Well"
	quest.196A5C0A9F2F5CED.quest_subtitle: "Kill 100 Pillager"
	quest.196A5C0A9F2F5CED.title: "Between monster and human"
	quest.198A8A607D6D7E20.title: "Treetop Tavern"
	quest.19A27364EBA25514.quest_desc: ["Prove you are strong by killing the &4Wilden Chimera&r! The drop from this boss will allow you to craft the &5Mark of mastery&r and the &5Focus of summoning&r."]
	quest.19A27364EBA25514.title: "I'm the boss now"
	quest.19CD520F86C492A2.title: "Tumulus"
	quest.19CEBC1D82F725E1.quest_desc: ["Priority to damage, this is near endgame set for combat."]
	quest.19E3F66C7E92CCAB.quest_desc: [
		"Chunk loaders can be placed on stationary ground, moving contraptions, and trains. They require a lot of rotational force. There needs to be both enough power and enough speed to get the chunk loader working. "
		""
		"It is not recommended to place a chunk loader on a contraption that will continously load and unload chunks but it is possible. This is because of the lag that can generate."
		""
		"&bContinue on Next Page ->&r"
		"{@pagebreak}"
		"Placing the chunk loader off of a train station makes it no longer need rotational force. Rather, it will load chunks when a train is stopped at the station AND un/loading goods. This is helpful for transporting items across long distances."
		""
		"Using a chunk loader on a train is not recommended for just transporting items. Trains do not need chunks to be loaded in order to move them, so a chunk loader at a station will be more helpful in most situations. If the train is using rollers or ploughs or something, s chunk loader on the train itself may be helpful."
	]
	quest.19FD02262DBF8077.quest_desc: [
		"You can use chains as short distance fast travel!"
		""
		"Right click on fence while holding chain and connect it to second fence to connect them."
		""
		"Holding pickaxe holding right click makes You slide on it! "
	]
	quest.19FD02262DBF8077.quest_subtitle: "First, we connect them"
	quest.19FD02262DBF8077.title: "Riding on chains!"
	quest.1A1AA5526FE53525.quest_subtitle: "Water breathing for 10 seconds"
	quest.1A1DBEF38340AD10.title: "Cold Deciduous Forest"
	quest.1A28D62D184FA8B7.title: "Pink Salt Caves"
	quest.1AA6DF2E139D3130.quest_desc: [
		"&#1E5AA8Advanced Rite&r"
		""
		"Arcane energy gathers within the totem, but without direction it disperses violently."
		"The wood becomes scarred, forming Soulwood, a material that warps magic and alters the behavior of spirit rites."
		""
		"The Blight-Bound Rite Locus released by this unstable rite will transmute the block above whenever it travels through blight."
		""
		"One practical use of this uncontrolled transmutation is converting Runewood blocks and saplings into their Soulwood equivalents."
		"Soulwood can also replace Runewood when creating a Totem Base through Spirit Infusion."
		""
		""
		"[&#D546FF✧&r] &#D546FFArcane&r"
		"[&#D546FF✧&r] &#D546FFArcane&r"
		"[&#D546FF✧&r] &#D546FFArcane&r"
		"[&#D546FF✧&r] &#D546FFArcane&r"
		"[&#D546FF✧&r] &#D546FFArcane&r"
	]
	quest.1AA6DF2E139D3130.quest_subtitle: "Warp uncontrolled arcana"
	quest.1AB4DAE368D717C7.title: "Kutcha Village"
	quest.1ABCD6809DD0627B.quest_desc: ["Allows to pipe items into the storage system."]
	quest.1AC163B06D0FFC8F.quest_desc: ["Looks like a cocoa bean in the jungle canopy, but far from edible. The seed holds stimulant power and smells pleasant when roasted."]
	quest.1AC163B06D0FFC8F.quest_subtitle: "Bitter Seed"
	quest.1ADE21F3A1856D14.quest_desc: [
		"After learning the basics of primitive technology, producing brass alloy becomes a major step toward more advanced mechanisms."
		""
		"Unlocks &6Brass Age&r chapter."
	]
	quest.1ADE21F3A1856D14.quest_subtitle: "Advanced alloy"
	quest.1B0077FC8B70BE47.quest_desc: ["Kill 16 Cave Spider"]
	quest.1B0AABA3D71042DB.quest_desc: ["A &5Source Jar&r functions as a tank to contain source. Later, these will be used to power magic devices. "]
	quest.1B0AABA3D71042DB.quest_subtitle: "Mana Container"
	quest.1B330CA2422E5FE6.quest_desc: [
		"The &6Encased Fan&r creates air streams that move entities and items."
		"It can also process items using bulk actions."
		""
		"The direction of rotation controls the airflow."
		"One direction pushes air, the other pulls it."
		""
		"To perform processing, place a block in front of the fan:"
		""
		"&8● &6Blasting&r — Lava source"
		"&8● &6Washing&r — Water source"
		"&8● &6Haunting&r — Soul Campfire"
		"&8● &6Smoking&r — Campfire"
	]
	quest.1B330CA2422E5FE6.quest_subtitle: "Air streams and bulk processing"
	quest.1B40A0C4AE03DE92.title: "Rocky Meadow"
	quest.1B4599B19EBFD1D0.quest_desc: [
		"Long ago, before players or villagers or even creepers, dinosaurs called the Overworld their home. But disaster struck, and they were forced to flee deep underground into &aPrimordial Caves&r. The greatest and most deadly of the creatures within is the &cLuxtructosaurus&r. This dinosaur causes nearby other volcanoes to erupt, has a powerful stomp attack that can level terrain, and can enter an enraged state that grants it the ability to breathe flames in addition to creating fissures in the ground with its stomp."
		"{@pagebreak}"
		"The Luxtructosaurus can be spawned by throwing an &6Ominous Catalyst&r onto an active Volcanic Core in the &2Primordial Caves&r biome."
	]
	quest.1B57F6F420F3B000.quest_desc: [
		"The End is a cosmic dimension that corrupts everything drawn into its existence."
		""
		"It is as beautiful as it is dangerous."
		""
		"If you seek true power, reaching it will not be easy — but it cannot be avoided."
		""
		"Unlocks &6End&r chapter."
	]
	quest.1B57F6F420F3B000.quest_subtitle: "Cosmic void"
	quest.1B57F6F420F3B000.title: "The End"
	quest.1B654BE8B33871F5.quest_desc: ["Be hell warrior, will full set grant 4 utilities buff, the sword allow you to stay alive longer with ignis ability"]
	quest.1B654BE8B33871F5.title: "Hell Warrior"
	quest.1B7786D30593CCAE.quest_subtitle: "&l&n&5Power of the wind!"
	quest.1BC3DA7400EA4A2A.title: "Astral Hideaway"
	quest.1BD7614BCF857898.title: "I will build!"
	quest.1BF4159B502AE4FF.quest_desc: [
		"The &6Deployer&r performs player-like actions for automation."
		""
		"It is used for crafting steps, Sequenced Assemblies, and tasks like polishing or waxing."
		""
		"Deployers can right- or left-click blocks and entities, allowing them to shear sheep, milk cows, place blocks, and more."
	]
	quest.1BF4159B502AE4FF.quest_subtitle: "Automation tool"
