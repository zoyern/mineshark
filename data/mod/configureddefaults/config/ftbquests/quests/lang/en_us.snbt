	quest.1FCFB1C0A752EC28.quest_subtitle: "See no evil, feel no evil"
	quest.1FE39FE01E79CAE5.quest_desc: ["A mysterious stone etched with runes, absorbing &8Void&r energy to grow stronger. It can summon &5Obelisks&r that restore its power. To defeat it, you must first destroy these obelisks, then strike the Obsidilith itself. Its purpose remains unknown, lost to history."]
	quest.1FFAE9F112A5F74C.quest_desc: [
		"The &6Experience Hatch&r allows depositing or extracting experience from a &6Fluid Tank&r or &6Basin&r."
		"    "
		""
		"&eInteraction&r"
		"Right-click to deposit experience."
		"Shift + Right-click to extract experience."
		""
		"&eScroll Panel&r"
		"Adjusts how much experience is transferred per interaction."
	]
	quest.1FFAE9F112A5F74C.quest_subtitle: "Experience transfer"
	quest.200DAB66214382B8.title: "Nature Coven"
	quest.2010601F09ADF6D6.quest_desc: [
		"The &6Wrench&r is used to rotate, dismantle, and configure &6Create&r blocks."
		""
		"Right-click a block to rotate it based on the face you click."
		"Some blocks—such as redstone devices or rails—will be dismantled instead and returned to your inventory."
		""
		"Blocks that normally use right-click interactions must be dismantled while &6sneaking&r."
		""
		"Some Create blocks support extra configuration."
		"Hover over them with the &6Wrench&r and use the scroll wheel to adjust settings."
		""
		"For blocks like the &6Linear Chassis&r, holding &6Ctrl&r while scrolling applies the change to all connected parts."
		""
		"&8● &6Quick Configuration&r"
		"When looking at certain Create blocks (for example a &6Gearbox&r), press &6U&r to open a radial menu with additional options such as block orientation."
	]
	quest.2010601F09ADF6D6.quest_subtitle: "Utility tool"
	quest.2062B1A841F4053C.quest_desc: [
		"The &bBrilliant Obelisk&r enhances enchanting."
		""
		"It provides power equal to five bookshelves."
		""
		"Place it near your enchanting setup for stronger enchants."
	]
