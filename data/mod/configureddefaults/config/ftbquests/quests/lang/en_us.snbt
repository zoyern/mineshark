	quest.6A1FA3085162F2D2.title: "&#4BF3DARite Of Ascension&r"
	quest.6A363CCF59A64C50.quest_subtitle: "Allows rolling while sprinting"
	quest.6A4B331DE0D91C04.quest_desc: [
		"The &6Conductor’s Baton&r lets you fix misconfigured &6Mechanical Arms&r, &6Pipettes&r, or &6Ejectors&r without breaking them."
		""
		"It allows adjusting their configuration directly."
	]
	quest.6A4B331DE0D91C04.quest_subtitle: "Reconfiguration"
	quest.6A67EA9C70D23736.quest_desc: [
		"A familiar deeply connected to the natural world."
		"It uses nature magic to support life around it."
		""
		"&9Abilities:&r"
		""
		"• Causes nearby crops to grow."
		""
		"• Breeds nearby animals."
		""
		"&dHabitat:&r"
		""
		"Often found protecting the &aforests&r of the world."
	]
	quest.6A67EA9C70D23736.quest_subtitle: "Keeper of Nature"
	quest.6A67EA9C70D23736.title: "Druid"
	quest.6A7B6273BC629C77.quest_desc: [
		"A &bHammer&r lets you customize your furniture to your heart's content!"
		""
		"Use on &bchairs&r to switch the back style, &bshelves&r and &bwooden pedestals&r to toggle item rotation, and &bcrates&r to prop them up/down."
	]
	quest.6A7B6273BC629C77.quest_subtitle: "Become a Carpenter!"
	quest.6A7CF35643697AE0.title: "Dead Upside Down Forest"
	quest.6AC6B49A1006475A.quest_desc: [
		"The &aGorgon&r was once a beautiful woman but is now cursed into a monster and trapped within a deadly maze. But despite her appearance being a curse, she has slain many adventurers with her stony gaze. Avert your eyes, lest you fall to the same fate. Many adventurers before you found a &6blindfold&r to be a helpful tool against this foe."
		""
		"&cWARN: The Gorgon can PERMANENTLY DELETE your armor if you turn to stone and die! This is a known bug. Fight the Gorgon at your armor's own risk."
		"{@pagebreak}"
		"The Gorgon is located within the &6&kLabyrinth&r. Follow &b\"The Mighty &kLabyrinth&r&b\"&r rumor to find her."
	]
	quest.6B1DEDA32CA51BAD.quest_desc: ["The first step to the brass age is creating brass. Makes sense, right? In order to make brass, you'll need to heat a basin using a blaze burner. Take your empty blaze burner into the nether and r-click a blaze with it. The blaze will now stay in the blaze burner indefinitely. Don't forget to feed it!"]
	quest.6B1DEDA32CA51BAD.title: "Things are Heating Up!"
	quest.6B3B060ED1B708B9.quest_subtitle: "Aerial Arsenal Ability. Lightning school bonus."
	quest.6B3B060ED1B708B9.title: "Mechanized Exoskeleton Armor"
	quest.6B5C6DA5D92C3FB6.quest_desc: [
		"&6Umvuthi&r sits upon his throne in the sun-drenched groves, creator of the &aAbavuthana&r. He draws power from the sun, calling down &esunstrikes, solar flares,&r and massive &6solar beams&r to smite intruders."
		""
		"He can also bring his followers to life—&aUmvuthana&r, including healers known as &bUmvuthana Cranes&r—from enchanted masks. These masked children worship him as a god."
		""
		"Unprepared travelers should keep their distance, but those strong enough to defeat him are rewarded with the &eSol Visage&r mask. It allows the wearer to animate masks and create followers—but the sun’s true power remains with &6Umvuthi&r, lost when he falls. Perhaps another path exists to harness it…"
	]
	quest.6B9EEA486F89EB3F.quest_desc: [
		"&#1E5AA8Advanced Rite&r"
		""
		"While active, it weaves a Bound Rite Locus."
		"Furnaces touched by the Locus smelt items much faster."
		""
