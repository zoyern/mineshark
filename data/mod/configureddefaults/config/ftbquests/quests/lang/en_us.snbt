	quest.63E776C9321E9407.quest_desc: [
		"Give Familiars small chance to block attacks."
		""
		"Created using &bShield&r or found in the world."
	]
	quest.63E776C9321E9407.quest_subtitle: "Blocking!"
	quest.6401E42DBD93997A.quest_desc: ["A great method to heat machines. I wonder how to fill this with a blaze..."]
	quest.6402B5B6625731F0.quest_subtitle: "Take 500.000 Damage"
	quest.6402B5B6625731F0.title: "Diamond Skin"
	quest.64385462E003742A.quest_desc: ["Prove bee are strong. Wear bee armor set and beat &5Ender Dragon&r"]
	quest.6447492FAA873F93.quest_desc: ["Suspended in the sky, this floating steampunk city glows in hues of orange and green. Strange, gear-driven inhabitants roam its platforms, each dominated by a singular central eye or monocle. Enter with caution, this mechanical hive is as clever as it is imposing, and its secrets are tightly guarded."]
	quest.6447492FAA873F93.quest_subtitle: "Find a Mechanical Nest"
	quest.645FD518CDA984B7.quest_desc: [
		"&bSoulwoven Silk&r is a light but durable material infused with soul energy."
		""
		"It naturally insulates against arcane effects."
		""
		"Easier to shape and craft with than stone-based materials."
		""
		"Used in advanced magical equipment and decorations."
	]
	quest.645FD518CDA984B7.quest_subtitle: "Arcane-insulated fabric"
	quest.647BB831AA2FF8C4.title: "Enderskog"
	quest.64A7804BB3AEFE86.quest_desc: [
		"The &bRunic Brooch&r allows you to equip runes."
		""
		"Wearing it unlocks rune slots."
		""
		"Each slot can hold one inscribed rune."
		""
		"Use it to activate rune effects without swapping trinkets."
	]
	quest.64A7804BB3AEFE86.quest_subtitle: "Equip rune effects"
	quest.64AD14BA422C2A84.quest_subtitle: "&l&n&5The hammer of the raging nether lord!"
	quest.64BAA6F2657DDED2.quest_desc: ["Trade 128 times with the &eBee Queen.&r"]
	quest.64FAE7341B7F29CA.quest_desc: [
		"&aPros:&r"
		"&8●&r Empty armor slots grant Armor and Armor Toughness"
		"&8●&r Empty armor slots increase healing received"
		""
		"&4Cons:&r"
		"&8●&r While wounded, empty armor slots damage you"
